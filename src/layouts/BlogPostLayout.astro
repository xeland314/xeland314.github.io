---
import BaseLayout from "../layouts/BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  bgColor?: string;
  extraFonts?: string;
  lang?: string;
}

const {
  title,
  description,
  bgColor = "bg-gray-200",
  extraFonts = "",
  lang = "es",
} = Astro.props;

const googleFontUrl = extraFonts
  ? `https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900${extraFonts}&display=swap`
  : "";
---

<BaseLayout
  title={title}
  description={description}
  keywords={title}
  author="xeland314"
  applicationName="xeland314 Blog"
  url={Astro.url.href}
  canonical={Astro.url.href}
  image="/assets/images/logo_v3.png"
  lang={lang}
>
  {googleFontUrl && <link rel="stylesheet" href={googleFontUrl} slot="head" />}

  <div class="fixed bottom-4 left-4 z-50 flex flex-col gap-2 print-hidden">
    <button
      id="btn-aspect-1-1"
      class="bg-slate-800 text-white hover:bg-slate-700 px-3 py-1.5 rounded-lg border border-slate-600 text-xs font-bold transition-all shadow-md active:scale-95"
    >
      Cuadrado (1:1)
    </button>
    <button
      id="btn-aspect-4-5"
      class="bg-slate-800 text-white hover:bg-slate-700 px-3 py-1.5 rounded-lg border border-slate-600 text-xs font-bold transition-all shadow-md active:scale-95"
    >
      Vertical (4:5)
    </button>
  </div>

  <div
    class={`min-h-screen ${bgColor} flex items-center justify-center overflow-hidden`}
  >
    <div id="scaler-wrapper-post" class="relative">
      <div
        id="canvas-target-post"
        class="canvas bg-[#0f172a] shadow-2xl overflow-hidden relative origin-top-left"
      >
        <slot />
      </div>
    </div>
  </div>
</BaseLayout>

<script>
  let targetHeight = 1080;
  const targetWidth = 1080;

  function initAspect() {
    // Recuperar preferencia guardada o usar 1080 por defecto
    const savedHeight = localStorage.getItem("blog-canvas-height");
    if (savedHeight) {
      targetHeight = parseInt(savedHeight, 10);
    }
    updateCanvasDimensions();
    scaleCanvas();
    updateButtonStates();
  }

  function updateCanvasDimensions() {
    const canvas = document.getElementById("canvas-target-post");
    if (canvas) {
      canvas.style.height = `${targetHeight}px`;
    }
  }

  function updateButtonStates() {
    const btn11 = document.getElementById("btn-aspect-1-1");
    const btn45 = document.getElementById("btn-aspect-4-5");
    
    if (!btn11 || !btn45) return;

    if (targetHeight === 1080) {
      btn11.classList.add("border-emerald-500", "bg-slate-900");
      btn45.classList.remove("border-emerald-500", "bg-slate-900");
    } else {
      btn45.classList.add("border-emerald-500", "bg-slate-900");
      btn11.classList.remove("border-emerald-500", "bg-slate-900");
    }
  }

  function scaleCanvas() {
    const wrapper = document.getElementById("scaler-wrapper-post");
    const canvas = document.getElementById("canvas-target-post");
    if (!wrapper || !canvas) return;

    const screenWidth = window.innerWidth;
    const screenHeight = window.innerHeight;

    // Calculamos la escala basada en el ancho y verificamos si se desborda en alto
    let scale = screenWidth / targetWidth;
    
    if (targetHeight * scale > screenHeight) {
      scale = screenHeight / targetHeight;
    }

    // Si la pantalla es más grande que el canvas real, dejamos de escalar (opcional)
    if (screenWidth >= targetWidth && screenHeight >= targetHeight) {
      canvas.style.transform = "none";
      wrapper.style.width = `${targetWidth}px`;
      wrapper.style.height = `${targetHeight}px`;
    } else {
      canvas.style.transform = `scale(${scale})`;
      wrapper.style.width = `${targetWidth * scale}px`;
      wrapper.style.height = `${targetHeight * scale}px`;
    }
  }

  // Setup de selectores
  function setupListeners() {
    document.getElementById("btn-aspect-1-1")?.addEventListener("click", () => {
      targetHeight = 1080;
      localStorage.setItem("blog-canvas-height", "1080");
      updateCanvasDimensions();
      scaleCanvas();
      updateButtonStates();
    });

    document.getElementById("btn-aspect-4-5")?.addEventListener("click", () => {
      targetHeight = 1350;
      localStorage.setItem("blog-canvas-height", "1350");
      updateCanvasDimensions();
      scaleCanvas();
      updateButtonStates();
    });
  }

  window.addEventListener("resize", scaleCanvas);
  window.addEventListener("DOMContentLoaded", () => {
    initAspect();
    setupListeners();
  });
  document.addEventListener("astro:page-load", () => {
    initAspect();
    setupListeners();
  });

  // Ejecución inicial por seguridad en recargas
  initAspect();
</script>

<style is:global>
  /* Global blog post styles migrated from header.php and common patterns */
  .code-font {
    font-family: "Fira Code", monospace;
  }

  /* Common utility for transparency/glass effect */
  .glass-tag {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .feature-card {
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
  }

  .highlight-blue {
    color: #38bdf8;
  }

  .canvas {
    width: 1080px;
    /* La altura se controla dinámicamente mediante JS */
    background: #0f172a;
  }

  /* Regla para ocultar los selectores durante impresiones o exportaciones a PDF/PNG */
  @media print {
    .print-hidden {
      display: none !important;
    }
  }
</style>