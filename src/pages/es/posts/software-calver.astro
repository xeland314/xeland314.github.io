---
import BlogPostLayout from "../../../layouts/BlogPostLayout.astro";
import RadiographyHeader from "../../../components/blog/RadiographyHeader.astro";
import RadiographyLegend from "../../../components/blog/RadiographyLegend.astro";
import PostFooterBar from "../../../components/blog/PostFooterBar.astro";

const title = "Versionamiento de Calendario";
const description = "Radiografía: CalVer YY.MM.Micro - Basado en el tiempo";
---

<BlogPostLayout
  title={title}
  description={description}
  bgColor="bg-slate-950"
  extraFonts="&family=Fira+Code:wght@400;700"
  lang="es"
>
  <div class="relative p-16 flex flex-col bg-slate-900 text-white overflow-hidden h-full">
    <div class="absolute top-4 right-4 z-50">
      <a
        href="/en/posts/software-calver"
        class="glass-tag print-hidden px-3 py-1 rounded text-slate-400 hover:text-white text-sm font-bold transition-colors"
        >EN</a
      >
    </div>

    <RadiographyHeader
      categoryText="Estándares de Software"
      categoryColorClass="text-amber-400"
      titlePrefix="Radiografía:"
      titleHighlightText="CalVer"
      titleHighlightColorClass="text-amber-400"
      subtitle="Calendar Versioning"
    />

    <div
      class="feature-card rounded-3xl p-6 mb-6 relative flex flex-row gap-8 items-center justify-center"
    >
      <div
        class="code-font text-8xl font-black tracking-tighter flex items-baseline"
      >
        <span class="text-slate-500 text-4xl mr-2">v</span>
        <span class="text-amber-400">26</span>
        <span class="text-slate-600">.</span>
        <span class="text-cyan-400">06</span>
        <span class="text-slate-600">.</span>
        <span class="text-purple-400">1</span>
      </div>

      <RadiographyLegend
        items={[
          {
            bgColor: "bg-amber-400",
            shadowRgba: "rgba(251,191,36,0.5)",
            textColor: "text-amber-400",
            title: "AÑO (YY / YYYY)",
            description: "Año de liberación. <br>Ej: 26 para 2026 o 2026 completo.",
          },
          {
            bgColor: "bg-cyan-400",
            shadowRgba: "rgba(34,211,238,0.5)",
            textColor: "text-cyan-400",
            title: "MES (MM / 0M)",
            description: "Mes de liberación. <br>Informa qué tan viejo es el software.",
          },
          {
            bgColor: "bg-purple-400",
            shadowRgba: "rgba(192,132,252,0.5)",
            textColor: "text-purple-400",
            title: "MICRO (OR PARCHE)",
            description: "Cambios menores o <br>correcciones dentro del ciclo.",
          },
        ]}
        gap="gap-8"
        minWidth="min-w-[240px]"
      />
    </div>

    <div class="grid grid-cols-2 gap-8 items-start mb-auto text-lg">
      <div class="space-y-4">
        <div class="glass-tag p-5 rounded-xl border-l-4 border-amber-400">
          <h4
            class="text-amber-400 font-bold text-2xl uppercase tracking-widest mb-1"
          >
            Regla de Oro
          </h4>
          <p class="text-slate-200 leading-snug text-xl">
            Las versiones se rigen por el <span class="font-bold text-white">calendario comercial</span>, 
            no por la compatibilidad de la API. Prioriza saber <span class="text-amber-400 font-black">CUÁNDO</span> 
            se lanzó el software.
          </p>
        </div>
        <div class="glass-tag p-5 rounded-xl border-l-4 border-cyan-400">
          <h4
            class="text-cyan-400 font-bold text-2xl uppercase tracking-widest mb-1"
          >
            Flexibilidad
          </h4>
          <p class="text-slate-200 leading-snug text-xl">
            No hay un formato único. Proyectos como Ubuntu usan <span class="code-font text-white bg-slate-800 px-2 rounded">YY.MM</span> 
            (24.04), mientras que otros prefieren <span class="code-font text-white bg-slate-800 px-2 rounded">YYYY.Micro</span>.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div class="feature-card p-4 rounded-2xl">
          <h3 class="text-amber-400 font-bold text-2xl mb-2">Casos de Uso</h3>
          <p class="text-slate-400 text-lg">
            Ideal para sistemas operativos, navegadores o apps con soporte a largo plazo (LTS).
          </p>
        </div>
        <div class="feature-card p-4 rounded-2xl">
          <h3 class="text-cyan-400 font-bold text-2xl mb-2">Lógica</h3>
          <p class="text-slate-400 text-lg">
            Visibilidad clara de la obsolescencia. Sabes al instante si tu versión tiene años de retraso.
          </p>
        </div>
        <div class="feature-card p-4 rounded-2xl">
          <h3 class="text-purple-400 font-bold text-2xl mb-2">Híbridos</h3>
          <p class="text-slate-400 text-lg">
            A veces se combina con SemVer, usando el año como MAJOR y el mes como MINOR.
          </p>
        </div>
        <div class="feature-card p-4 rounded-2xl">
          <h3 class="text-white font-bold text-2xl mb-2">Gigantes</h3>
          <p class="text-slate-400 text-lg">
            Utilizado por proyectos masivos como Ubuntu, Windows, JetBrains y pip.
          </p>
        </div>
      </div>
    </div>

    <PostFooterBar
      middleHtml='<span class="text-amber-400 font-black italic">YEAR</span> • <span class="text-cyan-400 font-black italic">MONTH</span> • <span class="text-purple-400 font-black italic">MICRO</span>'
    />
  </div>

  <style>
    .feature-card {
      background: rgba(251, 191, 36, 0.03);
      border: 1px solid rgba(251, 191, 36, 0.1);
    }
    .glass-tag {
      background: rgba(251, 191, 36, 0.05);
      border: 1px solid rgba(251, 191, 36, 0.2);
    }
  </style>
</BlogPostLayout>