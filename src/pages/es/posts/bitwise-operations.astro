---
import BlogPostLayout from "../../../layouts/BlogPostLayout.astro";
import RadiographyHeader from "../../../components/blog/RadiographyHeader.astro";
import RadiographyLegend from "../../../components/blog/RadiographyLegend.astro";
import PostFooterBar from "../../../components/blog/PostFooterBar.astro";

const title = "Operaciones Bitwise";
const description =
  "Radiografía de operadores binarios: manipulación directa de bits para optimización y algoritmos";
---

<BlogPostLayout
  title={title}
  description={description}
  bgColor="bg-slate-950"
  extraFonts="&family=Fira+Code:wght@400;700"
  lang="es"
>
  <div
    class="relative p-6 md:p-12 flex flex-col text-white overflow-hidden w-full h-full"
  >
    <div class="absolute top-4 right-4 z-50">
      <a
        href="/en/posts/bitwise-operations"
        class="glass-tag px-3 py-1 rounded text-slate-400 hover:text-white text-sm font-bold transition-colors"
        >EN</a
      >
    </div>

    <RadiographyHeader
      categoryText="Computer Science"
      categoryColorClass="text-sky-400"
      titlePrefix="Radiografía:"
      titleHighlightText="Bitwise Ops"
      titleHighlightColorClass="highlight-sky"
      subtitle="Manipulación Binaria Directa"
    />

    <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8 flex-1">
      <!-- Columna 1: Operadores Básicos -->
      <div class="flex flex-col gap-4">
        <div class="feature-card p-6 rounded-2xl border-l-4 border-emerald-500 bg-emerald-500/5 flex-1 flex flex-col justify-center">
          <h3 class="text-emerald-400 font-black text-3xl mb-1 italic">AND (&)</h3>
          <p class="text-sm text-slate-400 mb-2 uppercase font-bold tracking-wider">Ambos 1 → 1</p>
          <div class="code-font text-2xl bg-black/40 p-4 rounded-xl border border-white/5">
            <span class="text-slate-500 text-lg">101 & 011 = </span><span class="text-emerald-400 font-bold">001</span>
          </div>
        </div>

        <div class="feature-card p-6 rounded-2xl border-l-4 border-sky-500 bg-sky-500/5 flex-1 flex flex-col justify-center">
          <h3 class="text-sky-400 font-black text-3xl mb-1 italic">OR (|)</h3>
          <p class="text-sm text-slate-400 mb-2 uppercase font-bold tracking-wider">Cualquiera 1 → 1</p>
          <div class="code-font text-2xl bg-black/40 p-4 rounded-xl border border-white/5">
            <span class="text-slate-500 text-lg">101 | 011 = </span><span class="text-sky-400 font-bold">111</span>
          </div>
        </div>

        <div class="feature-card p-6 rounded-2xl border-l-4 border-purple-500 bg-purple-500/5 flex-1 flex flex-col justify-center">
          <h3 class="text-purple-400 font-black text-3xl mb-1 italic">XOR (^)</h3>
          <p class="text-sm text-slate-400 mb-2 uppercase font-bold tracking-wider">Diferentes → 1</p>
          <div class="code-font text-2xl bg-black/40 p-4 rounded-xl border border-white/5">
            <span class="text-slate-500 text-lg">101 ^ 011 = </span><span class="text-purple-400 font-bold">110</span>
          </div>
        </div>

        <div class="feature-card p-6 rounded-2xl border-l-4 border-rose-500 bg-rose-500/5 flex-1 flex flex-col justify-center">
          <h3 class="text-rose-400 font-black text-3xl mb-1 italic">NOT (~)</h3>
          <p class="text-sm text-slate-400 mb-2 uppercase font-bold tracking-wider">Invertir Bits</p>
          <div class="code-font text-2xl bg-black/40 p-4 rounded-xl border border-white/5">
            <span class="text-slate-500 text-lg">~0101 = </span><span class="text-rose-400 font-bold">1010</span>
          </div>
        </div>
      </div>

      <!-- Resto del espacio: Desplazamientos con Table -->
      <div class="md:col-span-3 flex flex-col justify-center px-4">
        <h3 class="text-amber-400 font-black text-4xl uppercase tracking-tighter italic mb-8">Desplazamientos (Shifting)</h3>
        
        <table class="w-full border-collapse">
          <thead>
            <tr class="text-left border-b-2 border-white/10">
              <th class="py-4 text-amber-200 text-2xl uppercase tracking-widest">Operador</th>
              <th class="py-4 text-amber-200 text-2xl uppercase tracking-widest px-6">Ejemplo</th>
              <th class="py-4 text-slate-400 text-2xl font-medium">Descripción Técnica</th>
            </tr>
          </thead>
          <tbody class="text-lg">
            <tr class="border-b border-white/5 group">
              <td class="py-8 font-black text-4xl text-white italic group-hover:text-amber-400 transition-colors tracking-tighter">&lt;&lt;</td>
              <td class="py-8 px-6">
                <div class="code-font bg-black/40 p-4 rounded-xl border border-white/5 inline-block">
                  <span class="text-slate-500">5 &lt;&lt; 1 = </span><span class="text-amber-400 font-bold">10</span>
                </div>
              </td>
              <td class="py-8 text-slate-300 leading-relaxed">
                Desplaza a la izquierda; añade <strong class="text-white">0s</strong> al final. Equivale a <strong class="text-amber-200 italic font-bold tracking-widest">x 2ⁿ</strong>.
              </td>
            </tr>
            <tr class="border-b border-white/5 group">
              <td class="py-8 font-black text-4xl text-white italic group-hover:text-amber-400 transition-colors tracking-tighter">&gt;&gt;</td>
              <td class="py-8 px-6">
                <div class="code-font bg-black/40 p-4 rounded-xl border border-white/5 inline-block">
                  <span class="text-slate-500">5 &gt;&gt; 1 = </span><span class="text-amber-400 font-bold">2</span>
                </div>
              </td>
              <td class="py-8 text-slate-300 leading-relaxed">
                Desplaza a la derecha; <strong class="text-white">mantiene el signo</strong> del número. Equivale a <strong class="text-amber-200 italic font-bold tracking-widest">/ 2ⁿ</strong>.
              </td>
            </tr>
            <tr class="group">
              <td class="py-8 font-black text-4xl text-white italic group-hover:text-amber-400 transition-colors tracking-tighter">&gt;&gt;&gt;</td>
              <td class="py-8 px-6">
                <div class="code-font bg-black/40 p-4 rounded-xl border border-white/5 inline-block">
                  <span class="text-slate-500 text-sm">-5 &gt;&gt;&gt; 1 = </span><span class="text-amber-400 font-bold text-xl">2147483645</span>
                </div>
              </td>
              <td class="py-8 text-slate-300 leading-relaxed">
                Desplazamiento lógico; rellena con <strong class="text-white">0s</strong> a la izquierda sin importar el signo original.
              </td>
            </tr>
          </tbody>
        </table>

    <!-- Propiedades en Grid 2x2 (Final del post) -->
    <div class="grid grid-cols-2 gap-6 mb-auto pt-4">
      <div class="glass-tag p-8 rounded-2xl border-l-8 border-purple-500 bg-purple-500/5">
        <div class="flex items-center gap-6">
          <code class="text-purple-300 text-4xl font-bold bg-black/40 p-5 rounded-2xl border border-white/5">x ^ x = 0</code>
          <div>
            <h4 class="text-white font-bold text-2xl uppercase mb-1">Auto-anulación</h4>
            <p class="text-slate-400 text-lg leading-tight">Cualquier número operado con XOR consigo mismo resulta en cero.</p>
          </div>
        </div>
      </div>
      <div class="glass-tag p-8 rounded-2xl border-l-8 border-purple-500 bg-purple-500/5">
        <div class="flex items-center gap-6">
          <code class="text-purple-300 text-4xl font-bold bg-black/40 p-5 rounded-2xl border border-white/5">x & (x-1)</code>
          <div>
            <h4 class="text-white font-bold text-2xl uppercase mb-1">Clear LSB</h4>
            <p class="text-slate-400 text-lg leading-tight">Elimina el bit menos significativo que esté activado (1).</p>
          </div>
        </div>
      </div>
      <div class="glass-tag p-8 rounded-2xl border-l-8 border-purple-500 bg-purple-500/5">
        <div class="flex items-center gap-6">
          <code class="text-purple-300 text-4xl font-bold bg-black/40 p-5 rounded-2xl border border-white/5">x & -x</code>
          <div>
            <h4 class="text-white font-bold text-2xl uppercase mb-1">Isolar LSB</h4>
            <p class="text-slate-400 text-lg leading-tight">Aísla el bit más a la derecha (Least Significant Bit) activado.</p>
          </div>
        </div>
      </div>
      <div class="glass-tag p-8 rounded-2xl border-l-8 border-purple-500 bg-purple-500/5">
        <div class="flex items-center gap-6">
          <code class="text-purple-300 text-4xl font-bold bg-black/40 p-5 rounded-2xl border border-white/5">x ^ 0 = x</code>
          <div>
            <h4 class="text-white font-bold text-2xl uppercase mb-1">Identidad</h4>
            <p class="text-slate-400 text-lg leading-tight">Cualquier bit operado con XOR 0 mantiene su valor original.</p>
          </div>
        </div>
      </div>
    </div>
      </div>



    </div>

    <PostFooterBar
      middleHtml='<span class="text-emerald-400 font-black italic">LOW LEVEL</span> logic • <span class="text-sky-400 font-black italic">BIT</span> manipulation • <span class="text-amber-400 font-black italic">PERFORMANCE</span>'
    />
  </div>

  <style>
    .highlight-sky { color: #38bdf8; }
    .glass-tag { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); }
  </style>
</BlogPostLayout>
