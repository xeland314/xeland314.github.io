---
import BlogPostLayout from "../../../layouts/BlogPostLayout.astro";
import RadiographyHeader from "../../../components/blog/RadiographyHeader.astro";
import RadiographyLegend from "../../../components/blog/RadiographyLegend.astro";
import PostFooterBar from "../../../components/blog/PostFooterBar.astro";

const title = "Cron Syntax";
const description =
  "Radiografía de la sintaxis Cron para la programación de tareas en sistemas Unix/Linux";
---

<BlogPostLayout
  title={title}
  description={description}
  bgColor="bg-slate-950"
  extraFonts="&family=Fira+Code:wght@400;700"
  lang="es"
>
  <div
    class="relative p-6 md:p-12 flex flex-col text-white overflow-hidden h-full"
  >
    <div class="absolute top-4 right-4 z-50">
      <a
        href="/en/posts/linux-cron-syntax"
        class="glass-tag px-3 py-1 rounded text-slate-400 hover:text-white text-sm font-bold transition-colors"
        >EN</a
      >
    </div>

    <RadiographyHeader
      categoryText="Linux Automation"
      categoryColorClass="text-purple-400"
      titlePrefix="Radiografía:"
      titleHighlightText="Cron Job"
      titleHighlightColorClass="text-purple-400"
      subtitle="Programación de Tareas (Crontab)"
    />

    <!-- Main Visual breakdown -->
    <div
      class="feature-card rounded-3xl px-8 py-6 mb-6 relative flex flex-col items-center justify-center"
    >
      <div class="flex gap-4 md:gap-8 items-center mb-10">
        <div class="flex flex-col items-center">
          <span class="text-rose-500 font-black text-5xl md:text-7xl">30</span>
          <span class="text-slate-500 text-md font-bold mt-2">MIN</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-blue-400 font-black text-5xl md:text-7xl">02</span>
          <span class="text-slate-500 text-md font-bold mt-2">HORA</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-emerald-400 font-black text-5xl md:text-7xl">*</span>
          <span class="text-slate-500 text-md font-bold mt-2">DOM</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-amber-400 font-black text-5xl md:text-7xl">*</span>
          <span class="text-slate-500 text-md font-bold mt-2">MES</span>
        </div>
        <div class="flex flex-col items-center">
          <span class="text-purple-400 font-black text-5xl md:text-7xl">1</span>
          <span class="text-slate-500 text-md font-bold mt-2">DOW</span>
        </div>
        <div class="flex flex-col items-center">
          <p class="text-slate-400 font-bold text-2xl code-font">
            /usr/bin/backup.sh
          </p>
          <span class="text-slate-500 text-md font-bold mt-2">Comando</span>
        </div>
      </div>

      <div class="w-full">
        <RadiographyLegend
          items={[
            {
              bgColor: "bg-rose-500",
              shadowRgba: "rgba(244,63,94,0.5)",
              textColor: "text-rose-400",
              title: "Minuto (0-59)",
              description: "Momento exacto de la hora.",
            },
            {
              bgColor: "bg-blue-500",
              shadowRgba: "rgba(59,130,246,0.5)",
              textColor: "text-blue-400",
              title: "Hora (0-23)",
              description: "Formato de 24 horas.",
            },
            {
              bgColor: "bg-emerald-500",
              shadowRgba: "rgba(16,185,129,0.5)",
              textColor: "text-emerald-400",
              title: "DOM (1-31)",
              description: "Día del Mes (Day of Month).",
            },
            {
              bgColor: "bg-amber-500",
              shadowRgba: "rgba(245,158,11,0.5)",
              textColor: "text-amber-400",
              title: "Mes (1-12)",
              description: "Enero a Diciembre.",
            },
            {
              bgColor: "bg-purple-500",
              shadowRgba: "rgba(168,85,247,0.5)",
              textColor: "text-purple-400",
              title: "DOW (0-6)",
              description: "Día de la Semana (Dom=0).",
            },
          ]}
          gap="flex-row gap-2 md:gap-6"
          minWidth="min-w-[140px]"
        />
      </div>
      <p class="text-slate-300 text-md leading-relaxed mt-4 italic">
        "Ejecuta el script a las <span class="text-white font-bold">02:30 AM</span> todos los <span class="text-white font-bold">Lunes</span> (1), sin importar el día del mes o el mes."
      </p>
    </div>

    <!-- Special Operators Row -->
    <div class="grid grid-cols-4 gap-4 mb-4">
      <div class="feature-card p-4 rounded-xl border border-white/5 bg-white/5 text-center">
        <h3 class="text-purple-400 font-bold text-2xl mb-1">*</h3>
        <p class="text-slate-400 text-sm">Comodín: Todos los valores</p>
      </div>
      <div class="feature-card p-4 rounded-xl border border-white/5 bg-white/5 text-center">
        <h3 class="text-purple-400 font-bold text-2xl mb-1">/</h3>
        <p class="text-slate-400 text-md">Intervalos: <code class="text-white italic">*/15</code> (cada 15)</p>
      </div>
      <div class="feature-card p-4 rounded-xl border border-white/5 bg-white/5 text-center">
        <h3 class="text-purple-400 font-bold text-2xl mb-1">,</h3>
        <p class="text-slate-400 text-md">Lista: <code class="text-white italic">1,3,5</code> (solo esos)</p>
      </div>
      <div class="feature-card p-4 rounded-xl border border-white/5 bg-white/5 text-center">
        <h3 class="text-purple-400 font-bold text-2xl mb-1">-</h3>
        <p class="text-slate-400 text-md">Rango: <code class="text-white italic">1-5</code> (del 1 al 5)</p>
      </div>
    </div>

    <!-- Advanced Logic & Shortcuts -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-auto">
      <div class="flex flex-col glass-tag p-5 rounded-2xl border-l-4 border-purple-500 bg-purple-500/5">
        <h4 class="text-purple-400 font-bold text-lg uppercase mb-3 tracking-widest italic">Lógica DOM + DOW (OR)</h4>
        <div class="text-md leading-relaxed text-slate-300">
          <p class="mb-3 flex-1">
            Si ambos campos (Día del Mes y Día de la Semana) están restringidos (no son <code class="text-white">*</code>), la tarea se ejecutará cuando <strong>cualquiera</strong> de los dos coincida.
          </p>
          <div class="bg-black/30 p-3 rounded-lg border border-white/5">
            <code class="text-white font-bold text-lg">30 4 1,15 * 5</code>
            <p class="text-slate-400 text-md mt-1">4:30 AM los días 1 y 15, <strong>más</strong> todos los viernes.</p>
          </div>
        </div>
      </div>

      <div class="glass-tag p-5 rounded-2xl border-l-4 border-amber-500 bg-amber-500/5">
        <h4 class="text-amber-400 font-bold text-lg uppercase mb-2 tracking-widest italic">Atajos Especiales</h4>
        <div class="grid grid-cols-2 gap-x-4 gap-y-2 text-sm">
          <div class="flex flex-col border-b border-white/5 pb-1">
            <span class="text-white font-bold text-lg">@reboot</span>
            <span class="text-slate-500 text-[11px]">Al iniciar (daemon)</span>
          </div>
          <div class="flex flex-col border-b border-white/5 pb-1">
            <span class="text-white font-bold text-lg">@hourly</span>
            <span class="text-slate-500 text-[11px]">Cada hora (0 * * * *)</span>
          </div>
          <div class="flex flex-col border-b border-white/5 pb-1">
            <span class="text-white font-bold text-lg">@daily</span>
            <span class="text-slate-500 text-[11px]">Diario (0 0 * * *)</span>
          </div>
          <div class="flex flex-col border-b border-white/5 pb-1">
            <span class="text-white font-bold text-lg">@midnight</span>
            <span class="text-slate-500 text-[11px]">Mismo que @daily</span>
          </div>
          <div class="flex flex-col border-b border-white/5 pb-1">
            <span class="text-white font-bold text-lg">@weekly</span>
            <span class="text-slate-500 text-[11px]">Semanal (0 0 * * 0)</span>
          </div>
          <div class="flex flex-col border-b border-white/5 pb-1">
            <span class="text-white font-bold text-lg">@monthly</span>
            <span class="text-slate-500 text-[11px]">Mensual (0 0 1 * *)</span>
          </div>
          <div class="flex flex-col border-b border-white/5 pb-1">
            <span class="text-white font-bold text-lg">@yearly</span>
            <span class="text-slate-500 text-[11px]">Anual (0 0 1 1 *)</span>
          </div>
          <div class="flex flex-col border-b border-white/5 pb-1">
            <span class="text-white font-bold text-lg">@annually</span>
            <span class="text-slate-500 text-[11px]">Mismo que @yearly</span>
          </div>
        </div>
        <p class="text-slate-500 text-[10px] mt-2 italic">* @reboot se ejecuta al iniciar el daemon, posiblemente antes que otros servicios.</p>
      </div>
    </div>

    <PostFooterBar
      middleHtml='<span class="text-rose-400 font-black italic">MIN</span> • <span class="text-blue-400 font-black italic">HOUR</span> • <span class="text-emerald-400 font-black italic">DOM</span> • <span class="text-amber-400 font-black italic">MONTH</span> • <span class="text-purple-400 font-black italic">DOW</span>'
    />
  </div>

  <style>
    .highlight-purple { color: #a855f7; }
    .feature-card { background: rgba(168, 85, 247, 0.03); border: 1px solid rgba(168, 85, 247, 0.1); }
    .glass-tag { background: rgba(255, 255, 255, 0.03); backdrop-filter: blur(10px); }
  </style>
</BlogPostLayout>
