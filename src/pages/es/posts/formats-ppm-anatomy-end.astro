  firstText="¿Conocías el"
  secondText="Formato PPM?"
  finalText="PPM • Imagen • Minimalista"
  descriptionLine1="Si te apasiona el procesamiento de imágenes y el software,"
  descriptionLine2="considera seguirme para más contenido técnico."
  likeText="Me gusta"
  commentText="Comenta"
  saveText="Guarda"
  tailwindFirstColor="orange"
  tailwindSecondColor="amber"
  firstColor="#f97316"
  secondColor="#f59e0b"
/>