---
import ProjectLayout from "../../../layouts/ProjectLayout.astro";

const title = "StatLens - Explorador de Distribuciones Estadísticas Moderno";
const description =
  "Herramienta avanzada para explorar 13 modelos de probabilidad con gráficas dinámicas, fórmulas LaTeX y exportación a Excel.";
const keywords =
  "estadística, distribuciones, python, pyside6, matplotlib, latex, probabilidad";
const author = "Christopher Villamarín";
const applicationName = "StatLens";
const url = "https://xeland314.github.io/es/projects/statlens/";
const image = "/images/statlens_pixel_cat.png";
const imageAlt = "Logo de StatLens";
const robots = "index, follow";
const canonical = "https://xeland314.github.io/es/projects/statlens/";

const features = [
  {
    title: "13 Distribuciones",
    desc: "Soporte completo para modelos como Binomial, Normal, Poisson, Gamma y F.",
  },
  {
    title: "Gráficas Dinámicas",
    desc: "Visualización en tiempo real con Matplotlib para analizar el comportamiento de las funciones.",
  },
  {
    title: "Renderizado LaTeX",
    desc: "Visualiza fórmulas matemáticas complejas con alta fidelidad directamente en la UI.",
  },
  {
    title: "Exportación a Excel",
    desc: "Genera tablas de resultados detalladas y expórtalas a archivos .xlsx.",
  },
];
---

<ProjectLayout
  title={title}
  description={description}
  keywords={keywords}
  author={author}
  applicationName={applicationName}
  url={url}
  image={image}
  imageAlt={imageAlt}
  robots={robots}
  canonical={canonical}
  lang="es"
>
  <header class="text-center mb-12">
    <div class="flex justify-center mb-6">
      <img
        src={image}
        alt={imageAlt}
        class="w-24 h-24 transform transition hover:rotate-12"
      />
    </div>
    <h1 class="text-4xl md:text-5xl font-black mb-6 tracking-tighter">
      Stat<span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-green-500">Lens</span>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
      La estadística moderna al alcance de tu mano. Analiza, visualiza y exporta distribuciones de probabilidad con precisión técnica.
    </p>
  </header>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-8">Capacidades Analíticas</h2>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {
        features.map((feature) => (
          <div class="group p-8 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 hover:border-emerald-500/30 transition-all duration-300 shadow-sm">
            <h3 class="text-xl font-bold mb-3 text-gray-900 dark:text-white">
              {feature.title}
            </h3>
            <p class="text-gray-600 dark:text-gray-400 leading-relaxed">
              {feature.desc}
            </p>
          </div>
        ))
      }
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-6">Detalles Técnicos</h2>
    <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed mb-6">
      StatLens es una modernización completa de herramientas estadísticas clásicas, aprovechando el ecosistema de Python 3.12 y la potencia de PySide6 para la interfaz de usuario.
    </p>
    <ul class="space-y-4">
      <li class="flex items-start gap-3">
        <span class="mt-1 text-emerald-500 font-bold">✓</span>
        <span>Cálculo de probabilidades por intervalos ($P(X \le x)$, $P(X > x)$).</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-1 text-emerald-500 font-bold">✓</span>
        <span>Integración con <strong>scipy.stats</strong> para máxima precisión matemática.</span>
      </li>
      <li class="flex items-start gap-3">
        <span class="mt-1 text-emerald-500 font-bold">✓</span>
        <span>Gestión de dependencias eficiente con <strong>uv</strong>.</span>
      </li>
    </ul>
  </section>

  <section class="mb-12 text-center p-12 rounded-3xl bg-gradient-to-br from-emerald-600/5 to-green-500/5 border border-emerald-500/10">
    <h2 class="text-3xl font-bold mb-6">Código Abierto</h2>
    <p class="mb-8 text-lg text-gray-600 dark:text-gray-400">Revisa la implementación y contribuye al proyecto en GitHub.</p>
    <a 
      href="https://github.com/xeland314/statlens" 
      target="_blank"
      class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-bold transition-all transform hover:-translate-y-1 shadow-lg shadow-emerald-600/20"
    >
      Ver en GitHub
    </a>
  </section>
</ProjectLayout>
