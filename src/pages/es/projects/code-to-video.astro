---
import ProjectLayout from "../../../layouts/ProjectLayout.astro";

const title = "Code to Video - Christopher Villamarín Projects";
const description = "Genera videos animados de código siendo escrito directamente en tu navegador. Una herramienta potente para crear contenido educativo y tutoriales de programación de forma dinámica.";
const keywords = "Code to Video, Animación de Código, Programación, Tutoriales, Herramienta Desarrollador, Christopher Villamarín";
const author = "Christopher Alexander Villamarín Pila";
const applicationName = "Code to Video";
const url = "https://xeland314.github.io/es/projects/code-to-video/";
const image = "https://xeland314.github.io/assets/images/logo_v3.png";
const imageAlt = "Vista previa de la herramienta Code to Video";
const robots = "index, follow";
const canonical = "https://xeland314.github.io/es/projects/code-to-video/";
---

<ProjectLayout
  title={title}
  description={description}
  keywords={keywords}
  author={author}
  applicationName={applicationName}
  url={url}
  image={image}
  imageAlt={imageAlt}
  robots={robots}
  canonical={canonical}
  lang="es"
>
  <header class="text-center mb-12">
    <h1 class="text-4xl md:text-5xl font-black mb-6 tracking-tighter">
      Code to <span class="text-transparent bg-clip-text bg-gradient-to-r from-indigo-600 to-purple-500">Video</span>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
      Transforma tu código en animaciones fluidas de escritura. Ideal para tutoriales, redes sociales y presentaciones técnicas.
    </p>
  </header>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-4">🎥 ¿Qué es Code to Video?</h2>
    <p class="text-lg mb-6 leading-relaxed text-gray-700 dark:text-gray-300">
      Es una herramienta innovadora que permite capturar el proceso de escritura de código y convertirlo en un archivo de video. Olvídate de grabar tu pantalla manualmente; con esta herramienta puedes definir el código, elegir un tema y generar una animación de "typewriter" perfecta en segundos.
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
      <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm">
        <h3 class="text-xl font-bold mb-2">⌨️ Animación de Escritura</h3>
        <p class="text-gray-600 dark:text-gray-400">Simula la escritura de código en tiempo real con velocidad ajustable para captar la atención de tu audiencia.</p>
      </div>
      <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm">
        <h3 class="text-xl font-bold mb-2">🎬 Exportación Directa</h3>
        <p class="text-gray-600 dark:text-gray-400">Genera archivos de video compatibles con la mayoría de reproductores y plataformas sociales directamente desde el canvas.</p>
      </div>
    </div>
  </section>

  <section class="mb-12 text-center p-12 rounded-3xl bg-gradient-to-br from-indigo-600/5 to-purple-500/5 border border-purple-500/10">
    <h2 class="text-3xl font-bold mb-6">🚀 Crea tu primera animación</h2>
    <p class="mb-8 text-lg text-gray-600 dark:text-gray-400">Dale vida a tus snippets de código ahora mismo.</p>
    <a 
      href="/code-to-video" 
      class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-indigo-600 hover:bg-indigo-700 text-white font-bold transition-all transform hover:-translate-y-1 shadow-lg shadow-indigo-600/20"
    >
      Abrir herramienta
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
  </section>
</ProjectLayout>
