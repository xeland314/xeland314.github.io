---
import ProjectLayout from "../../../layouts/ProjectLayout.astro";

const title = "Code to Image - Christopher Villamarín Projects";
const description = "Convierte tus fragmentos de código en imágenes elegantes con fondos personalizados para compartir en redes sociales. Una herramienta diseñada para desarrolladores que desean compartir su código de forma estética.";
const keywords = "Code to Image, Programación, Snippets, Exportar Código, Herramienta Desarrollador, Christopher Villamarín";
const author = "Christopher Alexander Villamarín Pila";
const applicationName = "Code to Image";
const url = "https://xeland314.github.io/es/projects/code-to-img/";
const image = "https://xeland314.github.io/assets/images/logo_v3.png";
const imageAlt = "Vista previa de la herramienta Code to Image";
const robots = "index, follow";
const canonical = "https://xeland314.github.io/es/projects/code-to-img/";
---

<ProjectLayout
  title={title}
  description={description}
  keywords={keywords}
  author={author}
  applicationName={applicationName}
  url={url}
  image={image}
  imageAlt={imageAlt}
  robots={robots}
  canonical={canonical}
  lang="es"
>
  <header class="text-center mb-12">
    <h1 class="text-4xl md:text-5xl font-black mb-6 tracking-tighter">
      Code to <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-500">Image</span>
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
      Eleva la presentación de tus fragmentos de código con imágenes profesionales listas para redes sociales.
    </p>
  </header>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-4">✨ ¿Qué es Code to Image?</h2>
    <p class="text-lg mb-6 leading-relaxed text-gray-700 dark:text-gray-300">
      Es una herramienta web diseñada para transformar código fuente plano en piezas visuales atractivas. Ya sea para un post en LinkedIn, un tweet o documentación técnica, esta herramienta te permite personalizar cada detalle del fondo y el estilo del editor.
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
      <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm">
        <h3 class="text-xl font-bold mb-2">🎨 Personalización Total</h3>
        <p class="text-gray-600 dark:text-gray-400">Cambia colores de fondo, gradientes y dimensiones para que se adapten a cualquier plataforma social.</p>
      </div>
      <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm">
        <h3 class="text-xl font-bold mb-2">⚡ Resaltado de Sintaxis</h3>
        <p class="text-gray-600 dark:text-gray-400">Soporta múltiples lenguajes de programación con temas oscuros y claros de alta legibilidad.</p>
      </div>
    </div>
  </section>

  <section class="mb-12 text-center p-12 rounded-3xl bg-gradient-to-br from-blue-600/5 to-indigo-500/5 border border-blue-500/10">
    <h2 class="text-3xl font-bold mb-6">🚀 ¡Pruébalo ahora!</h2>
    <p class="mb-8 text-lg text-gray-600 dark:text-gray-400">Empieza a crear imágenes de código impresionantes directamente en tu navegador.</p>
    <a 
      href="/code-to-img" 
      class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-blue-600 hover:bg-blue-700 text-white font-bold transition-all transform hover:-translate-y-1 shadow-lg shadow-blue-600/20"
    >
      Abrir herramienta
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
  </section>
</ProjectLayout>
