---
import ProjectLayout from "../../../layouts/ProjectLayout.astro";

const title = "¿Puedo usar mi GPU? - Christopher Villamarín Projects";
const description = "Verifica si tu navegador y hardware son compatibles con la aceleración por GPU para aplicaciones Flutter y WebGPU. Evalúa el soporte de WASM y la versión de OpenGL.";
const keywords = "GPU, WebAssembly, WASM, WebGPU, Flutter Web, Hardware Check, OpenGL, Christopher Villamarín";
const author = "Christopher Alexander Villamarín Pila";
const applicationName = "¿Puedo usar mi GPU?";
const url = "https://xeland314.github.io/es/projects/can-i-use-gpu/";
const image = "https://xeland314.github.io/assets/images/logo_v3.png";
const imageAlt = "Vista previa de la herramienta ¿Puedo usar mi GPU?";
const robots = "index, follow";
const canonical = "https://xeland314.github.io/es/projects/can-i-use-gpu/";
---

<ProjectLayout
  title={title}
  description={description}
  keywords={keywords}
  author={author}
  applicationName={applicationName}
  url={url}
  image={image}
  imageAlt={imageAlt}
  robots={robots}
  canonical={canonical}
  lang="es"
>
  <header class="text-center mb-12">
    <h1 class="text-4xl md:text-5xl font-black mb-6 tracking-tighter">
      ¿Puedo usar mi <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-600 to-teal-500">GPU</span>?
    </h1>
    <p class="text-xl text-gray-600 dark:text-gray-400 max-w-2xl mx-auto">
      Analiza la compatibilidad de tu entorno para ejecutar aplicaciones web de alto rendimiento.
    </p>
  </header>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-4">🔍 ¿Qué analiza esta herramienta?</h2>
    <p class="text-lg mb-6 leading-relaxed text-gray-700 dark:text-gray-300">
      Muchas aplicaciones modernas, especialmente las construidas con <strong>Flutter Web</strong> o <strong>WebGPU</strong>, requieren capacidades específicas del hardware y del navegador. Esta herramienta evalúa dos pilares fundamentales:
    </p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-8">
      <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm">
        <h3 class="text-xl font-bold mb-2 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-emerald-500"><path d="M20 16V4a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v12"/><path d="M2 20h20"/><path d="M16 20v-4H8v4"/></svg>
          Hardware y OpenGL
        </h3>
        <p class="text-gray-600 dark:text-gray-400">Verifica si posees una GPU funcional y una versión de OpenGL superior a la 2.0, necesaria para el renderizado avanzado y animaciones fluidas.</p>
      </div>
      <div class="p-6 rounded-2xl bg-white dark:bg-gray-800 border border-gray-100 dark:border-gray-700 shadow-sm">
        <h3 class="text-xl font-bold mb-2 flex items-center gap-2">
          <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-teal-500"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>
          Soporte WebAssembly
        </h3>
        <p class="text-gray-600 dark:text-gray-400">Comprueba si tu navegador puede ejecutar módulos <strong>WASM</strong>, un requisito indispensable para aplicaciones que demandan computación intensiva en la web.</p>
      </div>
    </div>
  </section>

  <section class="mb-12">
    <h2 class="text-3xl font-bold mb-4">💡 ¿Por qué es importante?</h2>
    <p class="text-lg text-gray-700 dark:text-gray-300 leading-relaxed">
      Saber si tu equipo es compatible te ayuda a diagnosticar por qué ciertas aplicaciones web se ven lentas o no cargan correctamente. Es especialmente útil para desarrolladores y usuarios de herramientas gráficas pesadas que dependen de la aceleración por hardware para funcionar.
    </p>
  </section>

  <section class="mb-12 text-center p-12 rounded-3xl bg-gradient-to-br from-emerald-600/5 to-teal-500/5 border border-emerald-500/10">
    <h2 class="text-3xl font-bold mb-6">⚙️ Ejecuta el diagnóstico</h2>
    <p class="mb-8 text-lg text-gray-600 dark:text-gray-400">Obtén un reporte detallado de las capacidades de tu navegador en un clic.</p>
    <a 
      href="/can-i-use-gpu" 
      class="inline-flex items-center gap-2 px-8 py-4 rounded-xl bg-emerald-600 hover:bg-emerald-700 text-white font-bold transition-all transform hover:-translate-y-1 shadow-lg shadow-emerald-600/20"
    >
      Verificar mi sistema
      <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
    </a>
  </section>
</ProjectLayout>
