---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CodeBlock from "../../components/common/CodeBlock";
import fs from "node:fs";
import path from "node:path";

const videos = [
  {
    id: "dragon_curve",
    title: "Dragon Curve",
    video: "/videos/dragon_curve.mp4",
    script: "dragon_curve_ppm.py",
  },
  {
    id: "hilbert_curve",
    title: "Hilbert Curve",
    video: "/videos/hilbert_curve.mp4",
    script: "hilbert_curve_ppm.py",
  },
  {
    id: "koch_snowflake",
    title: "Koch Snowflake",
    video: "/videos/koch_snowflake.mp4",
    script: "koch_snowflake_ppm.py",
  },
  {
    id: "mandelbrot",
    title: "Mandelbrot Zoom",
    video: "/videos/mandelbrot.mp4",
    script: "mandelbrot_ppm.py",
  },
  {
    id: "mandelbulb_3d",
    title: "Mandelbulb 3D",
    video: "/videos/mandelbulb_3d.mp4",
    script: "mandelbulb_3d.py",
  },
  {
    id: "burning_ship",
    title: "Burning Ship Fractal",
    video: "/videos/burning_ship.mp4",
    script: "burning_ship_ppm.py",
  },
  {
    id: "flower_bloom",
    title: "Flower Bloom (Julia)",
    video: "/videos/flower_bloom.mp4",
    script: "flower_bloom_ppm.py",
  },
  {
    id: "pythagoras_tree",
    title: "Pythagoras Tree",
    video: "/videos/pythagoras_tree.mp4",
    script: "pythagoras_tree_ppm.py",
  },
  {
    id: "sierpinski",
    title: "Sierpinski Gasket",
    video: "/videos/sierpinski.mp4",
    script: "sierpinski_ppm.py",
  },
];

const videosWithCode = videos.map((v) => {
  const filePath = path.join(process.cwd(), "public", "videos", v.script);
  const code = fs.readFileSync(filePath, "utf-8");
  return { ...v, code };
});

const siteTitle = "Math Animations Code | Christopher Villamarín";
const siteDescription =
  "Exploración de fractales y algoritmos visuales generados con Python y Raylib.";
---

<BaseLayout
  title={siteTitle}
  description={siteDescription}
  url={"/videos/"}
  canonical={"/videos/"}
  lang="es"
>
  <main class="min-h-screen bg-gray-50 dark:bg-gray-950 py-12 px-4 sm:px-8">
    <div class="max-w-6xl mx-auto">
      <header class="mb-16">
        <a
          href="/"
          class="text-blue-600 dark:text-blue-400 hover:underline mb-6 inline-flex items-center gap-2 font-bold transition-all hover:-translate-x-1"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-arrow-left"
            ><path d="m12 19-7-7 7-7"></path><path d="M19 12H5"></path></svg
          >
          Volver al inicio
        </a>
        <h1
          class="text-4xl md:text-6xl font-black text-gray-900 dark:text-white mb-6 tracking-tighter"
        >
          Math <span
            class="text-transparent bg-clip-text bg-gradient-to-r from-purple-600 to-blue-500"
            >Animations</span
          >
        </h1>
        <p
          class="text-xl text-gray-600 dark:text-gray-400 max-w-3xl leading-relaxed"
        >
          Una colección de fractales y algoritmos visuales generados con <span
            class="text-blue-600 dark:text-blue-400 font-bold">Python</span
          >, <span class="text-blue-600 dark:text-blue-400 font-bold"
            >NumPy</span
          > y <span class="text-blue-600 dark:text-blue-400 font-bold"
            >Raylib</span
          >. Cada video es el resultado de procesar miles de puntos matemáticos
          frame por frame.
        </p>
      </header>

      <div class="space-y-32">
        {
          videosWithCode.map((v) => (
            <section id={v.id} class="scroll-mt-10 group">
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-start">
                <div class="lg:sticky lg:top-10">
                  <div class="flex items-center gap-4 mb-6">
                    <span class="flex items-center justify-center w-10 h-10 rounded-full bg-purple-600 text-white font-bold shadow-lg shadow-purple-500/20">
                      {videosWithCode.indexOf(v) + 1}
                    </span>
                    <h2 class="text-3xl font-black text-gray-900 dark:text-white tracking-tight group-hover:text-purple-600 transition-colors">
                      {v.title}
                    </h2>
                  </div>
                  <div class="rounded-3xl overflow-hidden shadow-2xl bg-black aspect-square border-4 border-white dark:border-gray-800 ring-1 ring-gray-200 dark:ring-gray-700">
                    <video
                      src={v.video}
                      controls
                      loop
                      muted
                      autoplay
                      playsinline
                      class="w-full h-full object-cover"
                    />
                  </div>
                  <p class="mt-6 text-sm text-gray-500 dark:text-gray-400 italic">
                    * Animación generada exportando frames en formato PPM y
                    ensamblados con FFMPEG.
                  </p>
                </div>
                <div class="w-full overflow-hidden">
                  <div class="flex items-center justify-between mb-4">
                    <h3 class="text-xs font-black uppercase tracking-[0.2em] text-gray-400 dark:text-gray-500">
                      Python Source Code
                    </h3>
                    <span class="px-2 py-1 rounded bg-gray-100 dark:bg-gray-800 text-[10px] font-bold text-gray-500 uppercase tracking-wider border border-gray-200 dark:border-gray-700">
                      {v.script}
                    </span>
                  </div>
                  <div class="rounded-2xl overflow-hidden border border-gray-200 dark:border-gray-700 shadow-xl bg-gray-50 dark:bg-gray-900">
                    <CodeBlock client:load code={v.code} language="python" />
                  </div>
                </div>
              </div>
            </section>
          ))
        }
      </div>

      <footer
        class="mt-32 pt-16 border-t border-gray-200 dark:border-gray-800 text-center"
      >
        <p class="text-gray-500 dark:text-gray-400 font-medium">
          Christopher Villamarín &copy; {new Date().getFullYear()} - Hecho con Raylib
          y Python
        </p>
      </footer>
    </div>
  </main>
</BaseLayout>
