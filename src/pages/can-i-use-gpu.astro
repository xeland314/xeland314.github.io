---
import BaseLayout from "../layouts/BaseLayout.astro";

const title = "Can I Use GPU? | Detector de GPU para Aplicaciones Flutter";
const description =
  "Verifica si tu navegador y hardware son compatibles con aceleración por GPU para aplicaciones Flutter y WebGPU.";
const keywords =
  "GPU, Flutter, WebGL, WebGPU, Hardware Acceleration, Skia, Skwasm, Detector, Performance";
const author = "Christopher Alexander Villamarín Pila";
const url = "https://xeland314.github.io/can-i-use-gpu";
const image = "https://xeland314.github.io/assets/images/logo_v3.png";
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  author={author}
  url={url}
  image={image}
  canonical={url}
>
  <main
    class="min-h-screen bg-gray-50 dark:bg-gray-950 flex items-center justify-center p-4"
  >
    <div
      class="max-w-md w-full bg-white dark:bg-gray-900 rounded-3xl p-8 shadow-2xl border border-gray-200 dark:border-gray-800 transition-all"
    >
      <div id="detector-ui" class="text-center">
        <div
          class="mb-6 inline-flex p-4 bg-purple-100 dark:bg-purple-900/30 rounded-2xl text-purple-600 dark:text-purple-400"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="40"
            height="40"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-cpu"
            ><rect width="16" height="16" x="4" y="4" rx="2"></rect><rect
              width="6"
              height="6"
              x="9"
              y="9"
              rx="1"></rect><path d="M15 2v2"></path><path d="M15 20v2"
            ></path><path d="M2 15h2"></path><path d="M2 9h2"></path><path
              d="M20 15h2"></path><path d="M20 9h2"></path><path d="M9 2v2"
            ></path><path d="M9 20v2"></path></svg
          >
        </div>

        <h1
          class="text-2xl font-black tracking-tight mb-2 dark:text-white"
          id="status-title"
        >
          Detectando GPU para Flutter...
        </h1>
        <p class="text-gray-500 dark:text-gray-400 mb-8" id="status-desc">
          Verificando compatibilidad de hardware para ejecutar aplicaciones
          Flutter con motor Skia/Skwasm.
        </p>

        <div id="success-section" class="hidden">
           <div
            class="p-4 bg-green-50 dark:bg-green-900/20 border border-green-100 dark:border-green-900/30 rounded-2xl text-green-600 dark:text-green-400 mb-6"
          >
             <p class="text-sm font-medium">
               Hardware compatible detectado. Las aplicaciones locales funcionarán correctamente.
             </p>
           </div>
        </div>

        <div id="redirect-section" class="hidden">
          <div class="relative pt-1">
            <div
              class="overflow-hidden h-2 mb-4 text-xs flex rounded bg-purple-200 dark:bg-purple-900/50"
            >
              <div
                id="progress-bar"
                style="width:100%"
                class="shadow-none flex flex-col text-center whitespace-nowrap text-white justify-center bg-purple-600 transition-all duration-1000"
              >
              </div>
            </div>
            <p class="text-sm font-bold text-purple-600 dark:text-purple-400">
              Redirigiendo en <span id="countdown">5</span> segundos...
            </p>
          </div>
          <a
            id="manual-link"
            href="#"
            class="mt-6 inline-block text-xs text-gray-400 hover:text-purple-500 transition-colors underline"
            >Saltar espera</a
          >
        </div>

        <div id="error-section" class="hidden">
          <div
            class="p-4 bg-red-50 dark:bg-red-900/20 border border-red-100 dark:border-red-900/30 rounded-2xl text-red-600 dark:text-red-400 mb-6"
          >
            <p class="text-sm font-medium">
              No se detectó una GPU compatible o WebGPU no está habilitado en tu
              navegador.
            </p>
          </div>
          <p class="text-xs text-gray-500 mb-6">
            Esta aplicación requiere una GPU para funcionar correctamente
            (análisis local con Transformers/WASM).
          </p>
          <button
            onclick="location.reload()"
            class="w-full py-3 bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 rounded-xl font-bold hover:bg-gray-200 dark:hover:bg-gray-700 transition-all"
            >Reintentar</button
          >
        </div>

        <button
          id="btn-toggle-generator"
          class="mt-8 text-xs text-purple-600 dark:text-purple-400 hover:text-purple-700 hover:underline font-bold transition-colors"
        >
          Mostrar/Ocultar Generador de Enlaces
        </button>

        <div
          id="generator-section"
          class="hidden text-left border-t border-gray-100 dark:border-gray-800 pt-8 mt-4"
        >
          <h2
            class="text-sm font-bold uppercase tracking-wider text-gray-400 mb-4 text-center"
          >
            Generador de Enlaces
          </h2>
          <div class="space-y-4">
            <div>
              <label
                class="block text-[10px] font-bold text-gray-400 uppercase mb-1"
                >URL de Destino</label
              >
              <input
                type="url"
                id="input-url"
                placeholder="https://mi-app-gpu.com"
                class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm focus:ring-2 focus:ring-purple-500 outline-none dark:text-white"
              />
            </div>
            <div>
              <label
                class="block text-[10px] font-bold text-gray-400 uppercase mb-1"
                >Segundos (1-10)</label
              >
              <input
                type="number"
                id="input-time"
                min="1"
                max="10"
                value="5"
                class="w-full px-4 py-2 bg-gray-50 dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-lg text-sm focus:ring-2 focus:ring-purple-500 outline-none dark:text-white"
              />
            </div>
            <button
              id="btn-generate"
              class="w-full py-3 bg-purple-600 text-white rounded-xl font-bold hover:bg-purple-700 transition-all shadow-lg shadow-purple-500/20"
              >Generar Enlace Seguro</button
            >

            <div id="result-area" class="hidden">
              <label
                class="block text-[10px] font-bold text-gray-400 uppercase mb-1"
                >Tu enlace:</label
              >
              <div class="flex gap-2">
                <input
                  type="text"
                  id="output-url"
                  readonly
                  class="flex-1 px-3 py-2 bg-purple-50 dark:bg-purple-900/20 border border-purple-100 dark:border-purple-800 rounded-lg text-xs text-purple-700 dark:text-purple-300"
                />
                <button
                  id="btn-copy"
                  class="px-3 py-2 bg-purple-100 dark:bg-purple-900/40 text-purple-600 rounded-lg text-xs font-bold transition-colors hover:bg-purple-200"
                  >Copiar</button
                >
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>

  <script>
    import { checkGPU } from "../components/tools/gpuDetector";
    import { generateUrl } from "../components/tools/urlGenerator";

    const urlParams = new URLSearchParams(window.location.search);
    const targetUrl = urlParams.get("url");
    const waitTime = parseInt(urlParams.get("t") || "5") || 5;

    const statusTitle = document.getElementById("status-title");
    const statusDesc = document.getElementById("status-desc");
    const successSection = document.getElementById("success-section");
    const redirectSection = document.getElementById("redirect-section");
    const errorSection = document.getElementById("error-section");
    const generatorSection = document.getElementById("generator-section");
    const countdownEl = document.getElementById("countdown");
    const progressBar = document.getElementById("progress-bar");
    const manualLink = document.getElementById("manual-link");
    const btnToggleGenerator = document.getElementById("btn-toggle-generator");

    async function init() {
      // 1. Analyze hardware immediately
      const hasGPU = await checkGPU();

      if (!statusTitle || !statusDesc) return;

      if (hasGPU) {
        statusTitle.textContent = "Hardware Compatible";
        statusDesc.textContent = "Se ha detectado una GPU activa.";
        
        if (targetUrl) {
          // Hardware compatible AND URL provided -> handle redirect
          statusDesc.textContent += " Redirigiendo a la aplicación...";
          redirectSection?.classList.remove("hidden");
          if (manualLink) (manualLink as HTMLAnchorElement).href = targetUrl as string;

          let timeLeft = waitTime;
          if (countdownEl) (countdownEl as HTMLSpanElement).textContent = timeLeft.toString();

          const interval = setInterval(() => {
            timeLeft--;
            if (countdownEl) (countdownEl as HTMLSpanElement).textContent = timeLeft.toString();
            if (progressBar) (progressBar as HTMLDivElement).style.width = `${(timeLeft / waitTime) * 100}%`;

            if (timeLeft <= 0) {
              clearInterval(interval);
              window.location.href = targetUrl as string;
            }
          }, 1000);
        } else {
           // Hardware compatible BUT NO URL provided -> show success UI
           successSection?.classList.remove("hidden");
        }
      } else {
        // 2. Hardware incompatible -> show error
        statusTitle.textContent = "Hardware Incompatible";
        statusDesc.textContent = "Lo sentimos, tu dispositivo no cumple los requisitos.";
        errorSection?.classList.remove("hidden");
      }
    }

    // Generator logic
    const inputUrl = document.getElementById("input-url") as HTMLInputElement;
    const inputTime = document.getElementById("input-time") as HTMLInputElement;
    const btnGenerate = document.getElementById("btn-generate") as HTMLButtonElement;
    const resultArea = document.getElementById("result-area") as HTMLDivElement;
    const outputUrl = document.getElementById("output-url") as HTMLInputElement;
    const btnCopy = document.getElementById("btn-copy") as HTMLButtonElement;

    btnToggleGenerator?.addEventListener("click", () => {
      generatorSection?.classList.toggle("hidden");
    });

    btnGenerate?.addEventListener("click", () => {
      if (!inputTime || !inputUrl || !outputUrl || !resultArea) return;
      if (!inputUrl.value) return;
      
      const base = window.location.origin + window.location.pathname;
      const final = generateUrl(inputUrl.value, parseInt(inputTime.value) || 5, base);
      
      outputUrl.value = final;
      resultArea.classList.remove("hidden");
    });

    btnCopy?.addEventListener("click", () => {
      outputUrl.select();
      document.execCommand("copy");
      btnCopy.textContent = "¡Copiado!";
      setTimeout(() => (btnCopy.textContent = "Copiar"), 2000);
    });

    init();
  </script>
</BaseLayout>
