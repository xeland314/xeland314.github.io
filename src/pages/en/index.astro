---
import BaseLayout from "../../layouts/BaseLayout.astro";
import BentoGato from "../../components/bentos/BentoGato.astro";
import BentoVideos from "../../components/bentos/BentoVideos.astro";
import BentoEducation from "../../components/bentos/BentoEducation.astro";
import BentoProjects from "../../components/bentos/BentoProjects.astro";
import BentoTechStack from "../../components/bentos/BentoTechStack.astro";
import BentoPostGallery from "../../components/bentos/BentoPostGallery.astro";
import BentoServices from "../../components/bentos/BentoServices.astro";
import BentoDevTools from "../../components/bentos/BentoDevTools.astro";
import ContactForm from "../../components/contact/ContactForm";
import Footer from "../../components/common/Footer.astro";
import { db, Posts, Projects, eq, and, desc } from "astro:db";

const lang = "en";

const featuredProjects = await db
  .select()
  .from(Projects)
  .where(and(eq(Projects.lang, lang), eq(Projects.isFeatured, true)))
  .limit(6);

const recentPosts = await db
  .select()
  .from(Posts)
  .where(and(eq(Posts.lang, lang), eq(Posts.isPublished, true)))
  .orderBy(desc(Posts.id))
  .limit(6);

const siteTitle =
  "Christopher Villamarín - Software Developer | Backend | Programmer";
const siteDescription =
  "Christopher Villamarín - Transforming business problems into robust applications for Web, Mobile, and Desktop.";
const siteKeywords =
  "digital solutions, software development, web applications, mobile applications, desktop applications, Quito, Ecuador, xeland314";
const siteAuthor = "Christopher Alexander Villamarín Pila";
const siteUrl = "https://xeland314.github.io/en/";
const siteImage = "https://xeland314.github.io/images/preview-en.jpg";
---

<BaseLayout
  title={siteTitle}
  description={siteDescription}
  keywords={siteKeywords}
  author={siteAuthor}
  url={siteUrl}
  image={siteImage}
  canonical={siteUrl}
>
  <main
    id="main-content"
    class="min-h-screen [background-image:radial-gradient(circle,_#94a3b8_1px,_transparent_1px)] [background-size:24px_24px] dark:[background-image:radial-gradient(circle,_#334155_1px,_transparent_1px)] text-gray-900 dark:text-gray-200 py-6 px-4 sm:px-8 transition-colors duration-300 selection:bg-blue-500/30"
  >
    {/* Skip to content for keyboard navigation */}
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-blue-600 focus:text-white focus:rounded-lg focus:font-bold focus:shadow-lg"
    >
      Skip to main content
    </a>

    <div class="max-w-5xl mx-auto space-y-6">
      {/* 1. Profile and Featured Projects */}
      <section aria-label="Profile and featured projects">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
          <div class="md:col-span-5 lg:col-span-4">
            <div
              class="h-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl overflow-hidden"
            >
              <BentoGato lang={lang} />
            </div>
          </div>
          <div class="md:col-span-7 lg:col-span-8">
            <BentoProjects projects={featuredProjects} lang={lang} />
          </div>
        </div>
      </section>

      {/* 2. Technical Expertise and Education */}
      <section aria-label="Technical expertise and education">
        <div class="grid grid-cols-1 md:grid-cols-12 gap-4">
          <div class="md:col-span-7 lg:col-span-8">
            <BentoTechStack lang={lang} />
          </div>
          <div class="md:col-span-5 lg:col-span-4">
            <BentoEducation lang={lang} />
          </div>
        </div>
      </section>

      {/* 3. Recent Publications */}
      <section aria-label="Recent publications">
        <BentoPostGallery posts={recentPosts} lang={lang} />
      </section>

      {/* 4. Animations and Dev Tools (before footer) */}
      <section
        aria-label="Animations, demonstrations and developer tools"
      >
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
          <div class="lg:col-span-4">
            <div
              class="h-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl overflow-hidden"
            >
              <BentoVideos lang={lang} />
            </div>
          </div>
          <div class="lg:col-span-8">
            <BentoDevTools lang={lang} />
          </div>
        </div>
      </section>

      {/* 5. Contact and Services */}
      <section aria-label="Contact and services">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
          <div class="lg:col-span-7">
            <div
              class="h-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl overflow-hidden"
            >
              <ContactForm client:visible lang={lang} />
            </div>
          </div>
          <div class="lg:col-span-5">
            <BentoServices lang={lang} />
          </div>
        </div>
      </section>

      {/* 6. Footer */}
      <Footer />
    </div>
  </main>
</BaseLayout>
  </main>
</BaseLayout>
