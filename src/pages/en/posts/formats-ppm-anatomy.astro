---
import BlogPostLayout from "../../../layouts/BlogPostLayout.astro";
import RadiographyHeader from "../../../components/blog/RadiographyHeader.astro";
import RadiographyLegend from "../../../components/blog/RadiographyLegend.astro";
import PostFooterBar from "../../../components/blog/PostFooterBar.astro";

const title = "Image Formats";
const description = "Radiography: PPM Format - The base language of pixels";
---

<BlogPostLayout
  title={title}
  description={description}
  bgColor="bg-slate-900"
  extraFonts="&family=Fira+Code:wght@400"
  lang="en"
>
  <div
    class="relative p-8 md:p-16 flex flex-col text-white overflow-hidden h-full"
  >
    <!-- Language Link -->
    <div class="absolute top-4 right-4 z-50">
      <a
        href="/es/posts/formats-ppm-anatomy"
        class="glass-tag px-3 py-1 rounded text-slate-400 hover:text-white text-sm font-bold transition-colors"
      >
        ES
      </a>
    </div>

    <RadiographyHeader
      categoryText="Image Formats"
      categoryColorClass="text-orange-400"
      titlePrefix="Radiography:"
      titleHighlightText="PPM Format"
      titleHighlightColorClass="text-orange-500"
      subtitle="Portable Pixmap: Pixels in plain text"
    />

    <div
      class="feature-card rounded-3xl p-5 mb-4 relative flex flex-col md:flex-row gap-8 items-stretch"
    >
      <div
        class="code-font flex flex-col sm:flex-row gap-6 text-xl leading-relaxed flex-1 border-r border-white/10 pr-8"
      >
        <div
          class="shrink-0 overflow-hidden border border-white/20 shadow-lg aspect-[3/2] w-32 h-fit mt-2"
        >
          <img
            src="/ppm/example.png"
            alt="PPM Example 3x2 scaled"
            class="w-full h-full object-cover"
            width="128"
            height="85"
          />
        </div>
        <div>
          <p>
            <span
              class="text-pink-500 font-bold underline decoration-pink-500/30"
              >P3</span
            >
          </p>
        <p>
          <span class="text-blue-400 font-bold underline decoration-blue-400/30">3 2</span>
        </p>
        <p>
          <span class="text-emerald-400 font-bold underline decoration-emerald-400/30">255</span>
        </p>
        <p class="mt-2 text-sm text-slate-500 italic"># Row 1</p>
        <p>
          <span class="text-orange-500">255 0 0</span>  <span class="text-orange-500">0 255 0</span>  <span class="text-orange-500">0 0 255</span>
        </p>
        <p class="mt-2 text-sm text-slate-500 italic"># Row 2</p>
        <p>
          <span class="text-orange-500">255 255 0</span> <span class="text-orange-500">255 255 255</span> <span class="text-orange-500">0 0 0</span>
        </p>
      </div>

      <RadiographyLegend
        items={[
          {
            bgColor: "bg-pink-500",
            shadowRgba: "rgba(236,72,153,0.4)",
            textColor: "text-pink-500",
            title: "Magic Number",
            description: "P3 (ASCII) or P6 (Binary).",
          },
          {
            bgColor: "bg-blue-400",
            shadowRgba: "rgba(96,165,250,0.4)",
            textColor: "text-blue-400",
            title: "Dimensions",
            description: "Width and Height in pixels.",
          },
          {
            bgColor: "bg-emerald-500",
            shadowRgba: "rgba(16,185,129,0.4)",
            textColor: "text-emerald-500",
            title: "Max Value",
            description: "Maximum value for each channel.",
          },
          {
            bgColor: "bg-orange-500",
            shadowRgba: "rgba(249,115,22,0.4)",
            textColor: "text-orange-500",
            title: "RGB Data",
            description: "Sequence of R G B triples.",
          },
        ]}
        gap="gap-5"
        minWidth="min-w-[240px]"
      />
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-8 items-start">
      <div class="space-y-4">
        <div class="glass-tag p-4 rounded-xl">
          <h4
            class="text-orange-400 font-bold text-lg uppercase tracking-widest mb-1"
          >
            What is PPM?
          </h4>
          <p class="text-slate-200 leading-snug text-lg">
            <span class="font-bold text-white">Portable Pixmap</span> is an extremely simple image format, designed to be easy to read and write by programs without external libraries.
          </p>
        </div>
        <div class="glass-tag p-4 rounded-xl">
          <h4
            class="text-orange-400 font-bold text-lg uppercase tracking-widest mb-1"
          >
            Netpbm Variants
          </h4>
          <p class="text-slate-200 leading-snug text-lg">
            <span class="text-pink-400 font-bold">PBM</span> (B/W), 
            <span class="text-blue-400 font-bold">PGM</span> (Grayscale), 
            <span class="text-orange-400 font-bold">PPM</span> (RGB Color).
          </p>
          <p class="text-slate-400 text-lg mt-2">
            Perfect for learning and debugging graphics algorithms.
          </p>
          <a href="/ppm/gallery_gen.py" class="inline-block mt-4 text-orange-400 hover:text-orange-300 font-bold border-b border-orange-400/30 transition-all">
            View gallery generator code →
          </a>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4 mt-auto">
        <div class="feature-card p-6 rounded-2xl">
          <h3 class="text-orange-400 font-bold text-xl mb-2">Simplicity</h3>
          <p class="text-slate-400 text-lg">
            You can create an image with a simple text editor.
          </p>
        </div>
        <div class="feature-card p-6 rounded-2xl">
          <h3 class="text-orange-400 font-bold text-xl mb-2">No Compression</h3>
          <p class="text-slate-400 text-lg">
            Files are large, but they preserve every original bit.
          </p>
        </div>
        <div class="feature-card p-6 rounded-2xl">
          <h3 class="text-orange-400 font-bold text-xl mb-2">Interoperable</h3>
          <p class="text-slate-400 text-lg">
            Common bridge between different image formats.
          </p>
        </div>
        <div class="feature-card p-6 rounded-2xl">
          <h3 class="text-orange-400 font-bold text-xl mb-2">Debuggable</h3>
          <p class="text-slate-400 text-lg">
            Easy to inspect if something fails during rendering.
          </p>
        </div>
      </div>
    </div>

    <PostFooterBar
      middleHtml='<span class="text-pink-400 font-black italic">Pure Pixels</span> • <span class="text-orange-400 font-black italic">Crafted Software</span>.'
    />
  </div>

  <style>
    .feature-card {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.1);
    }
    .glass-tag {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid rgba(255, 255, 255, 0.2);
    }
  </style>
</BlogPostLayout>
