---
import BaseLayout from "../layouts/BaseLayout.astro";
import BentoHero from "../components/bentos/BentoHero.astro";
import BentoProjectsHeader from "../components/bentos/BentoProjectsHeader.astro";
import BentoMeHeader from "../components/bentos/BentoMeHeader.astro";
import BentoProfile from "../components/bentos/BentoProfile.astro";
import BentoLanguages from "../components/bentos/BentoLanguages.astro";
import BentoEducation from "../components/bentos/BentoEducation.astro";
import BentoExperience from "../components/bentos/BentoExperience.astro";
import BentoVideos from "../components/bentos/BentoVideos.astro";
import BentoCertificates from "../components/bentos/BentoCertificates.astro";
import BentoProjects from "../components/bentos/BentoProjects.astro";
import BentoTechStack from "../components/bentos/BentoTechStack.astro";
import BentoPostGallery from "../components/bentos/BentoPostGallery.astro";
import BentoServices from "../components/bentos/BentoServices.astro";
import BentoDevTools from "../components/bentos/BentoDevTools.astro";
import BentoBlog from "../components/bentos/BentoBlog.astro";
import ContactForm from "../components/contact/ContactForm";
import Footer from "../components/common/Footer.astro";
import { db, Posts, Projects, eq, and, desc } from "astro:db";

const lang = "es";

const featuredProjects = await db
  .select()
  .from(Projects)
  .where(and(eq(Projects.lang, lang), eq(Projects.isFeatured, true)))
  .limit(6);

const recentPosts = await db
  .select()
  .from(Posts)
  .where(and(eq(Posts.lang, lang), eq(Posts.isPublished, true)))
  .orderBy(desc(Posts.id))
  .limit(6);

const siteTitle =
  "Christopher Villamarín - Desarrollador de Software | Backend | Programador";
const siteDescription =
  "Christopher Villamarín - Transformo problemas de negocio en aplicaciones robustas para Web, Móvil y Escritorio.";
const siteKeywords =
  "soluciones digitales, desarrollo de software, aplicaciones web, aplicaciones móviles, aplicaciones de escritorio, Quito, Ecuador, xeland314";
const siteAuthor = "Christopher Alexander Villamarín Pila";
const siteUrl = "https://xeland314.github.io/";
const siteImage = "https://xeland314.github.io/images/preview-es.jpg";
---

<BaseLayout
  title={siteTitle}
  description={siteDescription}
  keywords={siteKeywords}
  author={siteAuthor}
  url={siteUrl}
  image={siteImage}
  canonical={siteUrl}
>
  <main
    id="main-content"
    class="min-h-screen [background-image:radial-gradient(circle,_#94a3b8_1px,_transparent_1px)] [background-size:24px_24px] dark:[background-image:radial-gradient(circle,_#334155_1px,_transparent_1px)] text-gray-900 dark:text-gray-200 py-6 px-4 sm:px-8 transition-colors duration-300 selection:bg-blue-500/30"
  >
    {/* Skip to content para navegación por teclado */}
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-blue-600 focus:text-white focus:rounded-lg focus:font-bold focus:shadow-lg"
    >
      Saltar al contenido principal
    </a>

    <div class="max-w-5xl mx-auto space-y-6">
      <div
        class="h-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl overflow-hidden"
      >
        <BentoHero lang={lang} />
      </div>

      {/* 1. Expertise Técnica, Educación y Experiencia */}
      <section
        aria-label="Expertise técnica, educación y experiencia"
        id="about"
        class="grid grid-cols-1 xl:grid-cols-12 gap-4"
      >
        <div class="xl:col-span-4 grid gap-4">
          <div class="flex flex-col gap-4">
            <BentoMeHeader lang={lang} />
            <BentoLanguages lang={lang} />
          </div>
        </div>

        <div class="xl:col-span-8">
          <BentoProfile lang={lang} />
        </div>

        <!-- Tech Stack: Una franja horizontal que destaca -->
        <div class="xl:col-span-12 grid gap-4 lg:grid-cols-12">
          <div class="lg:col-span-8">
            <BentoTechStack lang={lang} />
          </div>
          <div class="lg:col-span-4">
            <BentoCertificates lang={lang} />
          </div>
        </div>

        {/* Experience Row */}
        <div class="xl:col-span-12 grid gap-4 xl:grid-cols-2">
          <BentoEducation lang={lang} />
          <BentoExperience lang={lang} />
        </div>
      </section>

      {/* 2. Profile and Featured Projects */}
      <section aria-label="Profile and featured projects" id="projects">
        <div class="grid grid-cols-1 xl:grid-cols-12 gap-4">
          <div class="col-span-1 xl:col-span-4">
            <BentoProjectsHeader lang={lang} />
          </div>
          <div class="col-span-1 xl:col-span-8">
            <BentoProjects projects={featuredProjects} lang={lang} />
          </div>
        </div>
      </section>

      {/* 3. Publicaciones Recientes */}
      <section aria-label="Publicaciones recientes" id="blog">
        <div class="grid grid-cols-1 xl:grid-cols-12 gap-4">
          <div class="xl:col-span-4">
            <BentoBlog lang={lang} />
          </div>
          <div class="xl:col-span-8">
            <BentoPostGallery posts={recentPosts} lang={lang} />
          </div>
        </div>
      </section>

      {/* 4. Animaciones y Dev Tools (antes del footer) */}
      <section
        aria-label="Animaciones, demostraciones y herramientas para desarrolladores"
      >
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
          <div class="lg:col-span-4">
            <div
              class="h-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl overflow-hidden"
            >
              <BentoVideos lang={lang} />
            </div>
          </div>
          <div class="lg:col-span-8">
            <BentoDevTools lang={lang} />
          </div>
        </div>
      </section>

      {/* 5. Contacto y Servicios */}
      <section aria-label="Contacto y servicios" id="contact">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-4">
          <div class="lg:col-span-7">
            <div
              class="h-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl overflow-hidden"
            >
              <ContactForm client:visible lang={lang} />
            </div>
          </div>
          <div class="lg:col-span-5">
            <BentoServices lang={lang} />
          </div>
        </div>
      </section>

      {/* 6. Footer */}
      <Footer rounded />
    </div>
  </main>
</BaseLayout>
