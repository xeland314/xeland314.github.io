---
import BaseLayout from "../layouts/BaseLayout.astro";
import CodeToImage from "../components/tools/CodeToImage";

const siteTitle = "Code to Image Utility | Christopher Villamarín";
const siteDescription = "Herramienta personalizada para exportar fragmentos de código con fondos personalizados.";
---

<BaseLayout title={siteTitle} description={siteDescription}>
  <main class="min-h-screen bg-gray-50 dark:bg-gray-950">
    <div class="max-w-7xl mx-auto py-8 px-4 sm:px-8">
      <header class="mb-8">
        <a href="/" class="text-blue-600 dark:text-blue-400 hover:underline mb-4 inline-flex items-center gap-2 font-bold transition-all hover:-translate-x-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-arrow-left"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
          Volver al inicio
        </a>
        <h1 class="text-3xl font-black text-gray-900 dark:text-white tracking-tighter">
          Code to <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-600 to-indigo-500">Image</span>
        </h1>
        <p class="text-gray-600 dark:text-gray-400">Genera imágenes para tus posts con dimensiones personalizadas y fondos propios.</p>
      </header>

      <CodeToImage client:only="react" />
    </div>
  </main>
</BaseLayout>
