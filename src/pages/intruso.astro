---
import BaseLayout from "../layouts/BaseLayout.astro";

const siteTitle =
  "El Intruso — Detector de elemento exclusivo";
const siteDescription =
  "Detectar el elemento que no aparece en ningún otro grupo de letras o números. Ideal para razonamiento verbal y juegos de lógica.";
const siteKeywords =
  "razonamiento verbal, juegos de lógica, acertijos, intruso, elemento exclusivo, letras, números, combinaciones alfanuméricas";
const siteAuthor = "Christopher Alexander Villamarín Pila";
const siteUrl = "https://xeland314.github.io/";
const siteImage = "https://xeland314.github.io/assets/images/logo_v3.png";
---

<BaseLayout
  title={siteTitle}
  description={siteDescription}
  keywords={siteKeywords}
  author={siteAuthor}
  url={siteUrl}
  image={siteImage}
  canonical={siteUrl}
>
  <div 
    class="min-h-screen py-10 px-5 text-[#33393e] font-mono bg-[#eaf1f3]"
    style="background-image: linear-gradient(#d3e0e4 1px, transparent 1px), linear-gradient(90deg, #d3e0e4 1px, transparent 1px); background-size: 100% 32px, 32px 100%;"
  >
    <div class="max-w-[720px] mx-auto bg-white/55 border border-[#d3e0e4] rounded p-8 sm:p-9 shadow-[0_1px_0_rgba(0,0,0,0.03)]">
      <p class="text-[11px] tracking-[0.16em] text-[#8b98a3] uppercase mb-1.5">Razonamiento verbal · elemento exclusivo</p>
      <h1 class="font-serif font-bold text-[28px] mb-1.5 text-[#33393e]">El Intruso</h1>
      <p class="text-[#6b7680] font-serif text-[14.5px] leading-relaxed mb-[26px] max-w-[56ch]">
        Pega los grupos de letras o números. La herramienta marca, en cada
        grupo, el elemento que no aparece en ningún otro — y explica cuál es la
        respuesta preferida cuando hay más de un candidato.
      </p>

      <div class="mb-[22px]">
        <label for="input-groups" class="block text-xs tracking-[0.06em] uppercase text-[#6b7680] mb-2">
          Grupos (uno por línea, o separados por coma)
        </label>
        <textarea
          id="input-groups"
          class="w-full min-h-[110px] bg-white border border-[#d3e0e4] rounded-[3px] py-3 px-3.5 font-mono text-base tracking-[0.04em] text-[#33393e] resize-y focus:outline-2 focus:outline-[#c4392b] focus:outline-offset-1"
          placeholder="NMOPS
MSOPQ
PQRSM
QRSPM"
        ></textarea>
        <p class="text-[11.5px] text-[#8b98a3] mt-1.5 font-serif italic">
          Funciona igual con números o combinaciones alfanuméricas.
        </p>
      </div>

      <button
        id="btn-analizar"
        class="font-serif font-bold text-sm bg-[#33393e] text-white border-0 py-[11px] px-[22px] rounded-[3px] cursor-pointer tracking-[0.02em] hover:bg-[#1f2428] focus:outline-2 focus:outline-[#c4392b] focus:outline-offset-1"
      >
        Analizar grupos
      </button>

      <div id="resultado" class="mt-[30px]"></div>
    </div>
  </div>

  <style>
    .exclusive-char::after {
      content: "";
      position: absolute;
      left: -3px;
      right: -3px;
      top: -4px;
      bottom: -3px;
      border: 1.5px solid #c4392b;
      border-radius: 50%;
      transform: rotate(-4deg);
    }
  </style>

  <script is:inline>
    function parseGroups(raw) {
      return raw
        .split(/[\n,]/)
        .map((s) => s.trim().toUpperCase())
        .filter((s) => s.length > 0);
    }

    function analyze(groups) {
      const owners = new Map();
      groups.forEach((word, gi) => {
        const seen = new Set(word.split(""));
        seen.forEach((ch) => {
          if (!owners.has(ch)) owners.set(ch, new Set());
          owners.get(ch).add(gi);
        });
      });

      const perGroup = groups.map((word, gi) => {
        const exclusiveChars = [];
        [...new Set(word.split(""))].forEach((ch) => {
          if (owners.get(ch).size === 1) {
            exclusiveChars.push({ ch, pos: word.indexOf(ch) });
          }
        });
        exclusiveChars.sort((a, b) => a.pos - b.pos);
        return { gi, word, exclusiveChars };
      });

      const candidates = perGroup.filter((g) => g.exclusiveChars.length > 0);
      let winner = null;
      if (candidates.length > 0) {
        winner = candidates.reduce((best, cur) => {
          const curPos = cur.exclusiveChars[0].pos;
          const bestPos = best.exclusiveChars[0].pos;
          if (curPos < bestPos) return cur;
          if (curPos === bestPos && cur.gi < best.gi) return cur;
          return best;
        });
      }

      return { owners, perGroup, candidates, winner };
    }

    function renderWord(word, exclusiveChars) {
      const exclusivePositions = new Set(exclusiveChars.map((e) => e.pos));
      return word
        .split("")
        .map(
          (ch, i) =>
            `<span class="relative px-[1px]${exclusivePositions.has(i) ? " text-[#c4392b] font-bold exclusive-char" : ""}">${ch}</span>`,
        )
        .join("");
    }

    function render(groups, analysis) {
      const container = document.getElementById("resultado");
      const { owners, perGroup, candidates, winner } = analysis;

      if (candidates.length === 0) {
        container.innerHTML = `<p class="text-[#8b98a3] font-serif text-sm">Ningún grupo tiene un elemento que esté ausente en todos los demás. Revisa los datos, o puede que este set no siga ese patrón.</p>`;
        return;
      }

      const groupsHtml = perGroup
        .map((g) => {
          const isCandidate = g.exclusiveChars.length > 0;
          return `
      <div class="flex items-center gap-3.5 py-2 px-2.5 rounded-[3px]${isCandidate ? " bg-[#c4392b]/[0.06]" : ""}">
        <span class="font-serif italic text-[#8b98a3] text-xs w-[18px] shrink-0">${g.gi + 1}</span>
        <span class="text-[19px] tracking-[0.12em] relative">${renderWord(g.word, g.exclusiveChars)}</span>
        ${isCandidate ? `<span class="font-serif text-[11px] text-[#6b7680]">exclusivo: ${g.exclusiveChars.map((e) => `${e.ch} (pos. ${e.pos + 1})`).join(", ")}</span>` : ""}
      </div>`;
        })
        .join("");

      let reasoningHtml;
      if (candidates.length === 1) {
        const w = winner;
        const first = w.exclusiveChars[0];
        reasoningHtml = `La letra <code class="bg-white border border-[#d3e0e4] rounded-[2px] py-[1px] px-[5px] font-mono text-[#33393e]">${first.ch}</code> es la única de todo el conjunto que aparece en un solo grupo — el grupo ${w.gi + 1} (<code class="bg-white border border-[#d3e0e4] rounded-[2px] py-[1px] px-[5px] font-mono text-[#33393e]">${w.word}</code>), en la posición ${first.pos + 1}. Ningún otro grupo tiene un elemento exclusivo, así que no hay ambigüedad.`;
      } else {
        const others = candidates.filter((c) => c.gi !== winner.gi);
        const othersList = others
          .map(
            (c) =>
              `<code class="bg-white border border-[#d3e0e4] rounded-[2px] py-[1px] px-[5px] font-mono text-[#33393e]">${c.exclusiveChars[0].ch}</code> en el grupo ${c.gi + 1} (posición ${c.exclusiveChars[0].pos + 1})`,
          )
          .join("; ");
        const w = winner;
        const first = w.exclusiveChars[0];
        reasoningHtml = `Hay ${candidates.length} grupos con un elemento exclusivo: ${candidates.map((c) => `<code class="bg-white border border-[#d3e0e4] rounded-[2px] py-[1px] px-[5px] font-mono text-[#33393e]">${c.exclusiveChars[0].ch}</code> (grupo ${c.gi + 1})`).join(", ")}. Como puede haber varias respuestas válidas, se prioriza la que aparece primero dentro de su palabra: <code class="bg-white border border-[#d3e0e4] rounded-[2px] py-[1px] px-[5px] font-mono text-[#33393e]">${first.ch}</code> está en la posición ${first.pos + 1} del grupo ${w.gi + 1} (<code class="bg-white border border-[#d3e0e4] rounded-[2px] py-[1px] px-[5px] font-mono text-[#33393e]">${w.word}</code>), antes que ${othersList}.`;
      }

      const freqRows = [...owners.entries()]
        .sort((a, b) => a[1].size - b[1].size || a[0].localeCompare(b[0]))
        .map(
          ([ch, set]) => `
      <tr class="border-b border-[#d3e0e4]">
        <td class="py-1.5 px-2 text-left">${ch}</td>
        <td class="py-1.5 px-2 text-left ${set.size === 1 ? "text-[#c4392b] font-bold" : "text-[#8b98a3]"}">${set.size}</td>
        <td class="py-1.5 px-2 text-left">${[...set].map((gi) => gi + 1).join(", ")}</td>
      </tr>`,
        )
        .join("");

      container.innerHTML = `
      <div class="flex flex-col gap-2.5 my-[18px] mb-[22px]">${groupsHtml}</div>
      <div class="border-t border-dashed border-[#d3e0e4] pt-5 mt-1.5">
        <div class="flex items-baseline gap-2.5 mb-2.5">
          <span class="text-[#c4392b] font-serif font-bold text-[13px] uppercase tracking-[0.08em]">Respuesta</span>
          <span class="text-2xl text-[#c4392b] font-bold tracking-[0.1em]">${winner.word}</span>
        </div>
        <p class="font-serif text-[14.5px] leading-[1.65] text-[#33393e]">${reasoningHtml}</p>
      </div>
      <details class="mt-[22px] font-serif text-[13px]">
        <summary class="cursor-pointer text-[#6b7680] tracking-[0.02em]">Ver tabla de frecuencias por letra</summary>
        <table class="w-full border-collapse mt-3 font-mono text-[13px]">
          <thead>
            <tr class="border-b border-[#d3e0e4]">
              <th class="text-[#6b7680] font-semibold font-serif text-[11.5px] uppercase tracking-[0.04em] text-left py-1.5 px-2">Carácter</th>
              <th class="text-[#6b7680] font-semibold font-serif text-[11.5px] uppercase tracking-[0.04em] text-left py-1.5 px-2">Nº de grupos</th>
              <th class="text-[#6b7680] font-semibold font-serif text-[11.5px] uppercase tracking-[0.04em] text-left py-1.5 px-2">Aparece en grupo(s)</th>
            </tr>
          </thead>
          <tbody>${freqRows}</tbody>
        </table>
      </details>
    `;
    }

    document.getElementById("btn-analizar").addEventListener("click", () => {
      const raw = document.getElementById("input-groups").value;
      const groups = parseGroups(raw);
      if (groups.length < 2) {
        document.getElementById("resultado").innerHTML =
          `<p class="text-[#8b98a3] font-serif text-sm">Ingresa al menos dos grupos.</p>`;
        return;
      }
      render(groups, analyze(groups));
    });

    document.getElementById("input-groups").value =
      "NMOPS\nMSOPQ\nPQRSM\nQRSPM";
    document.getElementById("btn-analizar").click();
  </script>
</BaseLayout>
