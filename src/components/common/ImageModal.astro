---
import { Image } from "astro:assets";

interface Props {
  src: string;
  alt: string;
}

const { src, alt } = Astro.props;
---

<div class="image-wrapper cursor-pointer group">
  <Image
    src={src}
    alt={alt}
    title={alt}
    class="rounded-xl shadow-lg border border-gray-200 dark:border-gray-700 w-full transition group-hover:scale-[1.02] duration-300"
    onclick="this.closest('.image-wrapper').querySelector('dialog').showModal()"
    width={800}
    height={600}
  />

  <dialog
    class="modal-dialog p-0 bg-transparent w-[90vw] max-w-5xl rounded-xl border-none outline-none overflow-visible"
  >
    <!-- El contenedor relativo ahora envuelve todo, incluido el botón -->
    <div class="relative">
      <Image
        src={src}
        alt={alt}
        title={alt}
        class="w-full h-auto rounded-lg shadow-2xl block"
        width={1600}
        height={1200}
        quality="high"
      />

      <!-- Botón dentro de la imagen, esquina superior derecha -->
      <button
        onclick="this.closest('dialog').close()"
        class="absolute top-3 right-3 z-50 px-3 py-1.5 bg-black/60 text-white text-sm rounded-lg hover:bg-black/80 transition backdrop-blur-sm"
        aria-label="Cerrar"
      >
        ✕ Cerrar
      </button>
    </div>
  </dialog>
</div>

<style>
  dialog {
    margin: auto;
    max-height: 90vh;
    overflow-y: auto;
  }

  dialog::backdrop {
    backdrop-filter: blur(8px);
    background-color: rgba(0, 0, 0, 0.7);
  }

  dialog[open] {
    animation: zoomIn 0.3s ease-out;
  }

  @keyframes zoomIn {
    from {
      transform: scale(0.9);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }
</style>
