---
const currentPath = Astro.url.pathname;
const lang = currentPath.startsWith("/en") ? "en" : "es";

const texts: Record<string, Record<string, string>> = {
    es: {
        text: "Desarrollado con esmero y mucho código por",
        linkedin: "LinkedIn",
        github: "GitHub",
        instagram: "Instagram",
        threads: "Threads",
        email: "Copiar correo",
        copied: "¡Copiado!",
    },
    en: {
        text: "Developed with care and a lot of code by",
        linkedin: "LinkedIn",
        github: "GitHub",
        instagram: "Instagram",
        threads: "Threads",
        email: "Copy email",
        copied: "Copied!",
    },
};

const T = texts[lang];
---

<footer class="py-8 px-8 bg-gray-900 text-white">
    <div
        class="flex flex-col items-center gap-6 md:flex-row md:justify-between md:items-center mt-6"
    >
        <p class="text-center text-sm text-gray-400 md:text-left">
            {T.text}
            <span class="font-bold">xeland314</span>.
        </p>
        <div class="flex space-x-4 items-center">
            <a
                href="https://linkedin.com/in/christopher-villamarin"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 hover:text-white flex items-center transition-colors"
                aria-label={T.linkedin}
            >
                <svg
                    role="img"
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="currentColor"
                    class="w-6 h-6"
                >
                    <title>LinkedIn</title>
                    <path
                        d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
                    ></path>
                    <rect width="4" height="12" x="2" y="9"></rect>
                    <circle cx="4" cy="4" r="2"></circle>
                </svg>
                <span class="ml-2 hidden sm:inline">{T.linkedin}</span>
            </a>
            <a
                href="https://github.com/xeland314"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 hover:text-white flex items-center transition-colors"
                aria-label={T.github}
            >
                <svg
                    role="img"
                    viewBox="0 0 24 24"
                    xmlns="http://www.w3.org/2000/svg"
                    fill="currentColor"
                    class="w-6 h-6"
                >
                    <title>GitHub</title>
                    <path
                        d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"
                    ></path>
                </svg>
                <span class="ml-2 hidden sm:inline">{T.github}</span>
            </a>
            <a
                href="https://instagram.com/xeland314"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 hover:text-white flex items-center transition-colors"
                aria-label={T.instagram}
            >
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
                <span class="ml-2 hidden sm:inline">{T.instagram}</span>
            </a>
            <a
                href="https://threads.com/@xeland314"
                target="_blank"
                rel="noopener noreferrer"
                class="text-gray-400 hover:text-white flex items-center transition-colors"
                aria-label={T.threads}
            >
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><circle cx="12" cy="12" r="4"></circle><path d="M16 8v5a3 3 0 0 0 6 0v-1a10 10 0 1 0-4 8"></path></svg>
                <span class="ml-2 hidden sm:inline">{T.threads}</span>
            </a>
            <button
                id="copy-email-footer"
                class="text-gray-400 hover:text-white flex items-center transition-colors relative group"
                title={T.email}
            >
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-6 h-6"><rect width="20" height="16" x="2" y="4" rx="2"></rect><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"></path></svg>
                <span class="ml-2 hidden sm:inline">{T.email}</span>
                <span id="copy-success-footer" class="absolute -top-8 left-1/2 -translate-x-1/2 bg-white text-gray-900 text-[10px] font-bold px-2 py-1 rounded opacity-0 transition-opacity pointer-events-none">
                    {T.copied}
                </span>
            </button>
        </div>
    </div>
</footer>

<script>
  const copyBtn = document.getElementById("copy-email-footer");
  const successMsg = document.getElementById("copy-success-footer");

  const u = "christopher.villamarin";
  const d = "protonmail.com";

  copyBtn?.addEventListener("click", () => {
    navigator.clipboard.writeText(`${u}@${d}`);
    successMsg?.classList.remove("opacity-0");
    setTimeout(() => successMsg?.classList.add("opacity-0"), 2000);
  });
</script>
