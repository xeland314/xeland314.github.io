---
const { lang = "es" } = Astro.props;

const chatAnalyzerUrl = "https://xeland314.github.io/chat_analyzer_ui/";
const gpuRedirectUrl = `/can-i-use-gpu?url=${encodeURIComponent(chatAnalyzerUrl)}&t=5`;

const texts: Record<
  string,
  { title: string; subtitle: string; button: string; badge: string }
> = {
  es: {
    title: "Chat Analyzer",
    subtitle: "Analiza tus chats de WhatsApp localmente con IA. Requiere GPU.",
    button: "Abrir Aplicación",
    badge: "GPU Req",
  },
  en: {
    title: "Chat Analyzer",
    subtitle: "Analyze your WhatsApp chats locally with AI. GPU required.",
    button: "Open Application",
    badge: "GPU Req",
  },
};

const T = texts[lang];
---

<div
  class="h-full bg-gradient-to-br from-green-600 to-teal-700 rounded-3xl p-6 text-white flex flex-col justify-between overflow-hidden relative group border border-green-500/50 shadow-xl"
>
  <div class="absolute inset-0 opacity-10 group-hover:opacity-20 transition-opacity">
    <div class="absolute top-0 left-0 w-full h-full" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 20px 20px;"></div>
  </div>

  <div class="relative z-10">
    <div class="flex items-center justify-between mb-4">
        <div class="p-2 bg-white/10 rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-message-square-share"><path d="M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h7"/><path d="M16 5h5v5"/><path d="M15 10 21 4"/></svg>
        </div>
        <span class="px-2 py-0.5 text-[10px] font-bold bg-white/20 rounded-full border border-white/10">
            {T.badge}
        </span>
    </div>

    <h3 class="text-lg font-black tracking-tighter mb-2 italic">
      {T.title}
    </h3>
    <p class="text-xs text-green-50 font-medium opacity-90 leading-relaxed">
      {T.subtitle}
    </p>
  </div>

  <div class="relative z-10 mt-6">
    <a
      href={gpuRedirectUrl}
      class="inline-flex items-center justify-center gap-2 w-full py-2.5 px-4 bg-white text-green-700 hover:bg-green-50 text-xs font-bold rounded-xl transition-all shadow-lg hover:scale-[1.02] active:scale-[0.98]"
    >
      {T.button}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-cpu"><rect width="16" height="16" x="4" y="4" rx="2"/><rect width="6" height="6" x="9" y="9" rx="1"/><path d="M15 2v2"/><path d="M15 20v2"/><path d="M2 15h2"/><path d="M2 9h2"/><path d="M20 15h2"/><path d="M20 9h2"/><path d="M9 2v2"/><path d="M9 20v2"/></svg>
    </a>
  </div>
</div>
