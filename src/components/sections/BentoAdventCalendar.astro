---
const { lang = "es" } = Astro.props;

const adventUrl = "https://xeland314.github.io/advent-calendar/";

const texts: Record<
  string,
  { title: string; subtitle: string; button: string; badge: string }
> = {
  es: {
    title: "Advent Calendar",
    subtitle: "Calendario de adviento interactivo con temática retro-festiva.",
    button: "Abrir Calendario",
    badge: "Fun Tool",
  },
  en: {
    title: "Advent Calendar",
    subtitle: "Interactive advent calendar with retro-festive theme.",
    button: "Open Calendar",
    badge: "Fun Tool",
  },
};

const T = texts[lang];
---

<div
  class="h-full bg-gradient-to-br from-red-600 to-rose-700 rounded-3xl p-6 text-white flex flex-col justify-between overflow-hidden relative group border border-red-500/50 shadow-xl"
>
  <div class="absolute inset-0 opacity-10 group-hover:opacity-20 transition-opacity">
    <div class="absolute top-0 left-0 w-full h-full" style="background-image: radial-gradient(circle at 2px 2px, white 1px, transparent 0); background-size: 16px 16px;"></div>
  </div>

  <div class="relative z-10">
    <div class="flex items-center justify-between mb-4">
        <div class="p-2 bg-white/10 rounded-lg">
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-gift"><rect width="18" height="14" x="3" y="8" rx="2"/><path d="M12 5V3"/><path d="M7 12V8"/><path d="M17 12V8"/><path d="M7 8a2 2 0 0 1 2-2h6a2 2 0 0 1 2 2v4H7V8z"/></svg>
        </div>
        <span class="px-2 py-0.5 text-[10px] font-bold bg-white/20 rounded-full border border-white/10">
            {T.badge}
        </span>
    </div>

    <h3 class="text-lg font-black tracking-tighter mb-2 italic">
      {T.title}
    </h3>
    <p class="text-xs text-red-50 font-medium opacity-90 leading-relaxed">
      {T.subtitle}
    </p>
  </div>

  <div class="relative z-10 mt-6">
    <a
      href={adventUrl}
      target="_blank"
      class="inline-flex items-center justify-center gap-2 w-full py-2.5 px-4 bg-white text-red-700 hover:bg-red-50 text-xs font-bold rounded-xl transition-all shadow-lg hover:scale-[1.02] active:scale-[0.98]"
    >
      {T.button}
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-external-link"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
    </a>
  </div>
</div>
