---
const { lang = "es" } = Astro.props;

// Only videos under 1MB to ensure fast loading
const videos = [
  { src: "/videos/dragon_curve.mp4", title: "Dragon Curve" },
  { src: "/videos/sierpinski.mp4", title: "Sierpinski" },
  { src: "/videos/hilbert_curve.mp4", title: "Hilbert Curve" },
  { src: "/videos/koch_snowflake.mp4", title: "Koch Snowflake" },
];

// Select a random video
const randomVideo = videos[Math.floor(Math.random() * videos.length)];

const texts: Record<
  string,
  { title: string; subtitle: string; viewMore: string }
> = {
  es: {
    title: "Animaciones",
    subtitle: "Fractales y algoritmos con Python + Raylib",
    viewMore: "Ver todas",
  },
  en: {
    title: "Animations",
    subtitle: "Fractals and algorithms with Python + Raylib",
    viewMore: "View all",
  },
};

const T = texts[lang];
---

<div
  class="h-full bg-gray-600 dark:bg-gray-800 rounded-3xl p-4 text-white flex flex-col justify-between overflow-hidden relative group border border-gray-500/50 shadow-xl"
>
  {/* Decorative background circle */}
  <div
    class="absolute -top-10 -right-10 w-40 h-40 bg-gray-500 rounded-full opacity-30 group-hover:scale-110 transition-transform duration-700"
  >
  </div>

  <div class="relative z-10 flex items-center gap-6">
    <div class="flex-shrink-0">
      <div class="relative aspect-square w-32 h-32 rounded-xl overflow-hidden border border-white/10 group/video shadow-lg bg-black/20">
        <video
          id="random-animation-video"
          src={randomVideo.src}
          autoplay
          loop
          muted
          playsinline
          class="w-full h-full object-cover opacity-80 group-hover/video:opacity-100 transition-opacity"
        ></video>
        <div class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover/video:opacity-100 transition-opacity flex items-end p-1">
          <span id="random-animation-title" class="text-[6px] font-bold uppercase tracking-tighter text-white">
            {randomVideo.title}
          </span>
        </div>
      </div>
    </div>
    <div class="flex flex-col justify-center space-y-2">
      <h3 class="text-lg font-black tracking-tighter mb-0 italic text-gray-100">
        {T.title}
      </h3>
      <p class="text-xs text-gray-200 font-medium opacity-90 leading-relaxed">
        {T.subtitle}
      </p>
      <div>
        <a
          href="/videos"
          class="inline-flex items-center justify-center gap-2 py-2 px-3 bg-white/10 hover:bg-white/20 text-white text-xs font-bold rounded-xl transition-all border border-white/10 backdrop-blur-sm"
        >
          {T.viewMore}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3.5 h-3.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 11H5m14 0l-7-7m7 7l-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <script define:vars={{ videos }} is:inline>
    const videoElement = document.getElementById('random-animation-video');
    const titleElement = document.getElementById('random-animation-title');
    
    if (videoElement && titleElement) {
      const randomIndex = Math.floor(Math.random() * videos.length);
      const selected = videos[randomIndex];
      videoElement.src = selected.src;
      titleElement.textContent = selected.title;
    }
  </script>
