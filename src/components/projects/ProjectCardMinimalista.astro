---
interface Props {
  project: {
    title: string;
    description: string;
    shortDescription: string;
    githubLink?: string | null | undefined;
    demoLink?: string | null | undefined;
    tags: string[] | unknown;
    image?: string | undefined | null;
    slug: string;
  };
  lang?: "es" | "en";
  tags?: boolean;
}

const { project, lang = "es", tags = false } = Astro.props;

const texts = {
  es: {
    repository: "código",
    demo: "demo",
    repositoryLabel: `Ver código fuente de ${project.title} en GitHub`,
    demoLabel: `Ver demo en vivo de ${project.title}`,
    externalNotice: "(abre en nueva pestaña)",
  },
  en: {
    repository: "code",
    demo: "demo",
    repositoryLabel: `View source code for ${project.title} on GitHub`,
    demoLabel: `View live demo of ${project.title}`,
    externalNotice: "(opens in new tab)",
  },
};

const T = texts[lang];
const detailsPageLink = `/${lang}/projects/${project.slug}`;
---

<li
  class="group relative border-l-2 border-gray-200 dark:border-gray-700 pl-3 py-1.5 hover:border-blue-500 dark:hover:border-blue-400 transition-colors duration-200"
>
  <article aria-label={project.title}>
    <div class="flex items-start justify-between gap-2 mb-1">
      <h4 class="text-sm font-bold text-gray-900 dark:text-white font-mono">
        <a
          href={detailsPageLink}
          class="hover:text-blue-600 dark:hover:text-blue-400 transition-colors"
        >
          {project.title}
        </a>
      </h4>

      <nav
        aria-label={`Enlaces de ${project.title}`}
        class="flex items-center gap-2 flex-shrink-0"
      >
        {
          project.githubLink && (
            <a
              href={project.githubLink}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={T.repositoryLabel}
              class="text-[10px] text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-mono"
            >
              [{T.repository}]<span class="sr-only">{T.externalNotice}</span>
            </a>
          )
        }
        {
          project.demoLink && (
            <a
              href={project.demoLink}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={T.demoLabel}
              class="text-[10px] text-gray-500 dark:text-gray-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors font-mono"
            >
              [{T.demo}]<span class="sr-only">{T.externalNotice}</span>
            </a>
          )
        }
      </nav>
    </div>

    <p
      class="text-[11px] text-gray-600 dark:text-gray-300 mb-1 leading-relaxed line-clamp-2"
    >
      {project.shortDescription || project.description}
    </p>

    {
      tags && (
        <ul
          role="list"
          aria-label={`Tecnologías de ${project.title}`}
          class="flex flex-wrap gap-1.5"
        >
          {(project.tags as string[]).map((tag) => (
            <li class="text-[9px] text-gray-500 dark:text-gray-400 font-mono">
              #{tag}
            </li>
          ))}
        </ul>
      )
    }
  </article>
</li>
