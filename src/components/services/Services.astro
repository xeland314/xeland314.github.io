---
const services = [
  {
    icon: "🌐",
    name: "Sitio Web Corporativo",
    price: "Desde $200",
    days: "Entrega en 5 días",
    description:
      "Presencia digital sólida con diseño personalizado, secciones de servicios, información de contacto y formulario. Estructura optimizada para motores de búsqueda (SEO).",
    ideal:
      "Negocios, talleres y restaurantes que buscan captar clientes en Google.",
  },
  {
    icon: "⚙️",
    name: "Sistemas Web a Medida",
    price: "Bajo Cotización",
    days: "Tiempo a convenir",
    description:
      "Desarrollo de aplicaciones para control de inventario, registro de clientes, gestión de citas y pagos. Soluciones adaptadas a la lógica de tu negocio.",
    ideal:
      "Empresas en crecimiento que necesitan automatizar sus procesos internos.",
  },
];
---

<!-- SERVICIOS -->
<section class="space-y-4">
  <h2 class="text-2xl font-bold text-gray-900 dark:text-white px-2">
    Catálogo de Servicios
  </h2>
  <div class="grid gap-4">
    {
      services.map((s) => (
        <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 hover:border-blue-300 dark:hover:border-blue-700 transition-colors">
          <div class="flex flex-col sm:flex-row sm:items-start justify-between gap-4">
            <div class="flex items-start gap-4">
              <span class="text-3xl mt-1" aria-hidden="true">
                {s.icon}
              </span>
              <div class="space-y-1">
                <h3 class="font-bold text-lg text-gray-900 dark:text-white">
                  {s.name}
                </h3>
                <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed max-w-xl">
                  {s.description}
                </p>
                <p class="text-xs text-gray-500 pt-2">
                  <span class="font-semibold">Recomendado para:</span> {s.ideal}
                </p>
              </div>
            </div>
            <div class="sm:text-right shrink-0 bg-gray-50 dark:bg-gray-800 p-3 rounded-xl sm:bg-transparent sm:p-0">
              <p class="font-bold text-blue-600 dark:text-blue-400 text-lg">
                {s.price}
              </p>
              <p class="text-xs font-medium text-gray-500">{s.days}</p>
            </div>
          </div>
        </div>
      ))
    }
  </div>
</section>
