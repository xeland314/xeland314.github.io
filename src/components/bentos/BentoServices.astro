---
import BentoInternalHeader from "./BentoInternalHeader.astro";

const { lang = "es" } = Astro.props;

const texts: Record<
  string,
  {
    header: string;
    subheader: string;
    footer: string;
    ariaLabel: string;
    services: Array<{
      title: string;
      description: string;
      icon: string;
    }>;
  }
> = {
  es: {
    header: "Soluciones",
    subheader: "¿Qué problema resolvemos hoy?",
    footer: "Código eficiente enfocado en resultados",
    ariaLabel: "Preguntas frecuentes sobre servicios digitales",
    services: [
      {
        title: "Sistemas y Apps Internas",
        description:
          "¿Necesitas una plataforma interna centralizada para manejar los datos de tu empresa, controlar inventarios o conectar tus sistemas de forma segura?",
        icon: `<path d="M5 12h14"/><path d="M12 5v14"/><circle cx="12" cy="12" r="3"/><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2"/>`,
      },
      {
        title: "Automatización y Scripts",
        description:
          "¿Quieres descargar datos de una web automáticamente todos los días, procesar archivos masivos en segundos o eliminar tareas repetitivas?",
        icon: `<rect width="18" height="12" x="3" y="6" rx="2"/><path d="m7 10 2 2-2 2"/><path d="M11 14h4"/>`,
      },
      {
        title: "Sitios Web y Landing Pages",
        description:
          "¿Necesitas un sitio informativo o una landing page bilingüe (español/inglés) que cargue al instante y esté completamente optimizada para Google?",
        icon: `<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>`,
      },
      {
        title: "Control Local de Datos",
        description:
          "¿Quieres organizar la información crítica de tu negocio de forma segura dentro de tu red local, sin depender de internet ni pagar suscripciones?",
        icon: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/>`,
      },
    ],
  },
  en: {
    header: "Solutions",
    subheader: "What problem are we solving today?",
    footer: "Efficient code focused on results",
    ariaLabel: "Frequently asked questions about digital services",
    services: [
      {
        title: "Internal Systems & Apps",
        description:
          "Do you need a secure, centralized internal platform to manage business data, track inventory, or connect your tools?",
        icon: `<path d="M5 12h14"/><path d="M12 5v14"/><circle cx="12" cy="12" r="3"/><path d="M12 2a10 10 0 1 0 0 20A10 10 0 0 0 12 2"/>`,
      },
      {
        title: "Automation & Scripts",
        description:
          "Want to scrape data from a website daily, process massive files in seconds, or eliminate boring, repetitive manual tasks?",
        icon: `<rect width="18" height="12" x="3" y="6" rx="2"/><path d="m7 10 2 2-2 2"/><path d="M11 14h4"/>`,
      },
      {
        title: "Websites & Landing Pages",
        description:
          "Do you need an instant-loading, bilingual (English/Spanish) landing page or showcase website fully optimized for SEO?",
        icon: `<path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/>`,
      },
      {
        title: "Local-First Data Control",
        description:
          "Need to securely store and access your business information within your local network, without internet dependency or monthly subscription fees?",
        icon: `<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5"/><path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3"/>`,
      },
    ],
  },
};

const T = texts[lang];
---

<section
  aria-labelledby="services-heading"
  class="h-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl p-8 flex flex-col"
>
  <BentoInternalHeader title={T.header} subtitle={T.subheader} lang={lang} id="services-heading" />

  <ul
    role="list"
    aria-label={T.ariaLabel}
    class="space-y-6 flex-grow"
  >
    {
      T.services.map((service) => (
        <li class="flex gap-4">
          <div
            aria-hidden="true"
            class="w-8 h-8 rounded-lg bg-blue-500/10 text-blue-600 dark:text-blue-400 flex items-center justify-center shrink-0"
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="18"
              height="18"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
              focusable="false"
            >
              <Fragment set:html={service.icon} />
            </svg>
          </div>
          <div>
            <h4 class="text-xs font-bold text-gray-700 dark:text-gray-200 uppercase tracking-wider">
              {service.title}
            </h4>
            <p class="text-[10px] text-gray-500 mt-1 leading-relaxed dark:text-gray-400">
              {service.description}
            </p>
          </div>
        </li>
      ))
    }
  </ul>

  <footer
    class="mt-8 pt-6 border-t border-gray-200 dark:border-gray-800 text-center"
  >
    <p class="text-[9px] font-mono text-gray-400 uppercase tracking-widest">
      {T.footer}
    </p>
  </footer>
</section>