---
const { lang = "es" } = Astro.props;

const videos = [
  { src: "/videos/dragon_curve.mp4", title: "Dragon Curve" },
  { src: "/videos/sierpinski.mp4", title: "Sierpinski" },
  { src: "/videos/hilbert_curve.mp4", title: "Hilbert Curve" },
  { src: "/videos/koch_snowflake.mp4", title: "Koch Snowflake" },
];

const randomVideo = videos[Math.floor(Math.random() * videos.length)];

const texts: Record<
  string,
  {
    title: string;
    subtitle: string;
    viewMore: string;
    videoLabel: string;
    regionLabel: string;
  }
> = {
  es: {
    title: "Animaciones",
    subtitle: "Fractales y algoritmos con Python + Raylib",
    viewMore: "Ver todas",
    videoLabel: "Animación en reproducción",
    regionLabel: "Sección de animaciones matemáticas",
  },
  en: {
    title: "Animations",
    subtitle: "Fractals and algorithms with Python + Raylib",
    viewMore: "View all",
    videoLabel: "Currently playing animation",
    regionLabel: "Mathematical animations section",
  },
};

const T = texts[lang];
---

<section
  aria-label={T.regionLabel}
  class="relative flex flex-col items-center justify-center h-full bg-gray-50 dark:bg-gray-900 rounded-3xl p-4 text-gray-900 dark:text-white overflow-hidden group border border-gray-200 dark:border-gray-800 shadow-sm"
>
  {/* Círculo decorativo */}
  <div
    aria-hidden="true"
    class="absolute -top-10 -right-10 w-40 h-40 bg-blue-500/20 dark:bg-blue-600/15 rounded-full opacity-40 group-hover:scale-110 transition-transform duration-700"
  >
  </div>

  <div class="relative flex flex-col items-center gap-x-0 gap-y-2">
    {/* Video */}
    <div class="flex justify-center items-center">
      <figure
        class="relative aspect-square w-48 h-48 rounded-xl overflow-hidden border border-white/10 group/video shadow-lg bg-black/30"
      >
        <video
          id="random-animation-video"
          src={randomVideo.src}
          autoplay
          loop
          muted
          playsinline
          aria-label={`${T.videoLabel}: ${randomVideo.title}`}
          class="w-full h-full object-cover opacity-80 group-hover/video:opacity-100 transition-opacity"
        ></video>
        <figcaption
          class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover/video:opacity-100 transition-opacity flex items-end p-1"
        >
          <span
            id="random-animation-title"
            class="text-[12px] font-bold uppercase tracking-tighter text-white"
          >
            {randomVideo.title}
          </span>
        </figcaption>
      </figure>
    </div>

    {/* Texto y enlace */}
    <div class="flex flex-col justify-center items-center space-y-2">
      <h3 class="text-lg font-black tracking-tighter mb-0 italic text-gray-900 dark:text-white">
        {T.title}
      </h3>
      <p
        class="text-xs text-gray-600 dark:text-gray-400 font-medium leading-relaxed mb-2"
      >
        {T.subtitle}
      </p>
      <div>
        <a
          href={`/videos`}
          aria-label={T.viewMore + " — " + T.title}
          class="inline-flex items-center justify-center gap-2 py-2 px-3 bg-gray-100 dark:bg-gray-800/50 hover:bg-blue-100 dark:hover:bg-blue-900/30 text-gray-900 dark:text-white hover:text-blue-900 dark:hover:text-blue-200 text-xs font-bold rounded-xl transition-all duration-300 border border-gray-300 dark:border-gray-700 hover:border-blue-300 dark:hover:border-blue-700 hover:shadow-md dark:hover:shadow-lg dark:hover:shadow-blue-900/20"
        >
          {T.viewMore}

          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-3.5 h-3.5 transition-transform group-hover:translate-x-0.5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            aria-hidden="true"
            focusable="false"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M19 11H5m14 0l-7-7m7 7l-7 7"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>
</section>

<script define:vars={{ videos }} is:inline>
  const videoElement = document.getElementById("random-animation-video");
  const titleElement = document.getElementById("random-animation-title");

  if (videoElement && titleElement) {
    const randomIndex = Math.floor(Math.random() * videos.length);
    const selected = videos[randomIndex];
    videoElement.src = selected.src;
    videoElement.setAttribute(
      "aria-label",
      titleElement.closest("section")?.lang === "en"
        ? `Currently playing animation: ${selected.title}`
        : `Animación en reproducción: ${selected.title}`,
    );
    titleElement.textContent = selected.title;
  }
</script>
