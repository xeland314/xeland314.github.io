---
import BentoInternalHeader from "./BentoInternalHeader.astro";

const { lang = "es" } = Astro.props;

const videos = [
  { src: "/videos/dragon_curve.mp4", title: "Dragon Curve" },
  { src: "/videos/sierpinski.mp4", title: "Sierpinski" },
  { src: "/videos/hilbert_curve.mp4", title: "Hilbert Curve" },
  { src: "/videos/koch_snowflake.mp4", title: "Koch Snowflake" },
];

const randomVideo = videos[Math.floor(Math.random() * videos.length)];

const texts: Record<
  string,
  {
    title: string;
    subtitle: string;
    viewMore: string;
    videoLabel: string;
    regionLabel: string;
  }
> = {
  es: {
    title: "Animaciones",
    subtitle: "Fractales con Python + Raylib",
    viewMore: "Ver todas",
    videoLabel: "Animación en reproducción",
    regionLabel: "Sección de animaciones matemáticas",
  },
  en: {
    title: "Animations",
    subtitle: "Fractals with Python + Raylib",
    viewMore: "View all",
    videoLabel: "Currently playing animation",
    regionLabel: "Mathematical animations section",
  },
};

const T = texts[lang];
---

<section
  aria-labelledby="videos-heading"
  class="relative flex flex-col items-center justify-center w-full h-full bg-gray-50 dark:bg-gray-900 rounded-3xl p-4 text-gray-900 dark:text-white overflow-hidden group border border-gray-200 dark:border-gray-800 shadow-sm"
>
  <BentoInternalHeader
    title={T.title}
    subtitle={T.subtitle}
    href="/videos"
    lang={lang}
    id="videos-heading"
  />

  <div class="relative flex flex-col flex-1 items-center gap-x-0 gap-y-2">
    {/* Video */}
    <div class="flex justify-center items-center">
      <figure
        class="relative aspect-square w-48 h-48 rounded-xl overflow-hidden border border-white/10 group/video shadow-lg bg-black/30"
      >
        <video
          id="random-animation-video"
          src={randomVideo.src}
          autoplay
          loop
          muted
          playsinline
          aria-label={`${T.videoLabel}: ${randomVideo.title}`}
          class="w-full h-full object-cover opacity-80 group-hover/video:opacity-100 transition-opacity"
        ></video>
        <figcaption
          class="absolute inset-0 bg-gradient-to-t from-black/60 to-transparent opacity-0 group-hover/video:opacity-100 transition-opacity flex items-end p-1"
        >
          <span
            id="random-animation-title"
            class="text-[12px] font-bold uppercase tracking-tighter text-white"
          >
            {randomVideo.title}
          </span>
        </figcaption>
      </figure>
    </div>
  </div>
</section>

<script define:vars={{ videos }} is:inline>
  const videoElement = document.getElementById("random-animation-video");
  const titleElement = document.getElementById("random-animation-title");

  if (videoElement && titleElement) {
    const randomIndex = Math.floor(Math.random() * videos.length);
    const selected = videos[randomIndex];
    videoElement.src = selected.src;
    videoElement.setAttribute(
      "aria-label",
      titleElement.closest("section")?.lang === "en"
        ? `Currently playing animation: ${selected.title}`
        : `Animación en reproducción: ${selected.title}`,
    );
    titleElement.textContent = selected.title;
  }
</script>
