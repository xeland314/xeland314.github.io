---
import BentoInternalHeader from "./BentoInternalHeader.astro";

interface Props {
  lang: string;
}

const { lang } = Astro.props;

const labels = {
  es: {
    heading: "Idiomas",
    native: "Español Nativo",
    english: "Inglés C1",
  },
  en: {
    heading: "Languages",
    native: "Spanish Native",
    english: "English C1",
  },
};

const T = labels[lang as keyof typeof labels];
---

<section
  aria-labelledby="languages-heading"
  class="h-full bg-gray-50 dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-3xl p-6 flex flex-col"
>
  <BentoInternalHeader title={T.heading} lang={lang} id="languages-heading" />

  <div class="mt-0">
    <ul
      class="list-disc list-inside space-y-2 text-sm text-slate-700 dark:text-slate-300"
    >
      <li>{T.native}</li>
      <li>{T.english}</li>
    </ul>
  </div>
</section>
