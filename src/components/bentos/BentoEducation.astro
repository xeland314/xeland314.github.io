---
import BentoInternalHeader from "./BentoInternalHeader.astro";

const { lang = "es" } = Astro.props;

const texts = {
  es: {
    section_label: "Educación",
    items: [
      {
        institution: "Escuela Politécnica Nacional",
        degree: "Ingeniería de Software (Incompleto)",
        date: "sept. 2019 - mar. 2022",
        description: "4 semestres cursados.",
        skills: "Documentación técnica, Buenas prácticas de programación",
      },
      {
        institution: "Bachillerato Internacional",
        degree: "Programa del Diploma del IB",
        date: "sept. 2017 - jul. 2019",
        description: "Nota: 31/45.",
        skills: "Análisis de datos, Pensamiento científico",
      },
    ],
  },
  en: {
    section_label: "Education",
    items: [
      {
        institution: "Escuela Politécnica Nacional",
        degree: "Software Engineering (Incomplete)",
        date: "Sep 2019 - Mar 2022",
        description: "4 semesters completed.",
        skills: "Technical documentation, Programming best practices",
      },
      {
        institution: "International Baccalaureate",
        degree: "IB Diploma Programme",
        date: "Sep 2017 - Jul 2019",
        description: "Score: 31/45.",
        skills: "Data analysis, Scientific thinking",
      },
    ],
  },
};

const T = texts[lang as keyof typeof texts];
---

<section
  aria-labelledby="education-heading"
  class="h-full bg-gray-50 dark:bg-gray-900 rounded-3xl p-6 border border-gray-200 dark:border-gray-800 flex flex-col"
>
  <div>
    <BentoInternalHeader
      title={T.section_label}
      lang={lang}
      id="education-heading"
    />

    <ul role="list" aria-label={T.section_label} class="space-y-4 mt-4">
      {
        T.items.map((edu, index) => (
          <li
            role="listitem"
            class={`${index > 0 ? "pt-4 border-t border-gray-200 dark:border-gray-700" : ""}`}
          >
            <div class="flex justify-between items-start mb-1">
              <div>
                <h4 class="text-sm font-bold text-gray-900 dark:text-white">
                  {edu.institution}
                </h4>
                <p class="text-[11px] text-gray-500 dark:text-gray-400 mt-0.5">
                  {edu.degree}
                </p>
              </div>
              <span class="text-[11px] font-medium text-slate-500 dark:text-slate-400 whitespace-nowrap ml-4">
                {edu.date}
              </span>
            </div>

            {/* <p class="text-xs leading-relaxed text-slate-600 dark:text-slate-300 mt-2">
              {edu.description}
            </p> */}

            <div class="mt-3 flex gap-2 items-center">
              <svg
                class="w-3.5 h-3.5 text-slate-400 dark:text-slate-500"
                fill="none"
                viewBox="0 0 24 24"
                stroke="currentColor"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  stroke-width="2"
                  d="M 5 13l4 4L19 7"
                />
              </svg>
              <p class="text-[11px] text-slate-500 dark:text-slate-400 font-medium">
                {edu.skills}
              </p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>
