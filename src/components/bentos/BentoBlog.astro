---
import { db, Blogs, eq, and, desc } from "astro:db";

interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;

const latestBlogs = await db
  .select()
  .from(Blogs)
  .where(and(eq(Blogs.lang, lang), eq(Blogs.isPublished, true)))
  .orderBy(desc(Blogs.pubDate))
  .limit(3);

const labels = {
  es: {
    title: "BLOG",
    subtitle: "Tutoriales y notas",
    viewAll: "Ver todo",
  },
  en: {
    title: "BLOG",
    subtitle: "Tutorials and notes",
    viewAll: "View all",
  },
};

const t = labels[lang as keyof typeof labels];
---

<div class="flex flex-col h-full bg-gray-50 dark:bg-gray-900 border border-slate-200 dark:border-slate-800 rounded-3xl overflow-hidden group transition-all duration-500">
  <div class="p-6 pb-2 flex justify-between items-center">
    <div>
      <h3 class="text-xl font-black text-slate-900 dark:text-white tracking-tighter uppercase">
        {t.title}<span class="text-blue-600 dark:text-blue-400">_</span>
      </h3>
      <p class="text-[10px] text-slate-400 font-bold uppercase tracking-widest">{t.subtitle}</p>
    </div>
    <a 
      href={`/${lang}/blog`} 
      class="text-[10px] font-black text-slate-400 hover:text-blue-600 dark:hover:text-blue-400 transition-colors uppercase tracking-widest"
    >
      {t.viewAll} →
    </a>
  </div>

  <div class="flex-1 p-4 space-y-2">
    {latestBlogs.map((blog) => (
      <a 
        href={blog.url}
        class="flex flex-col p-3 rounded-2xl hover:bg-slate-50 dark:hover:bg-slate-800/50 transition-all group/item"
      >
        <time class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1">
          {new Date(blog.pubDate!).toLocaleDateString(lang, { year: 'numeric', month: 'short', day: 'numeric' })}
        </time>
        <h4 class="text-sm font-bold text-slate-800 dark:text-slate-200 truncate group-hover/item:text-blue-600 dark:group-hover/item:text-blue-400 transition-colors">
          {blog.title}
        </h4>
      </a>
    ))}
  </div>
  
  <div class="h-1 w-full bg-gradient-to-r from-transparent via-blue-500/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"></div>
</div>
