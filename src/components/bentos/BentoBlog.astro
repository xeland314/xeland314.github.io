---
import { db, Blogs, eq, and, desc } from "astro:db";
import BentoInternalHeader from "./BentoInternalHeader.astro";

interface Props {
  lang?: string;
}

const { lang = "es" } = Astro.props;

const latestBlogs = await db
  .select()
  .from(Blogs)
  .where(and(eq(Blogs.lang, lang), eq(Blogs.isPublished, true)))
  .orderBy(desc(Blogs.pubDate))
  .limit(6);

const labels = {
  es: {
    title: "Blog",
    subtitle: "Tutoriales y notas",
    viewAll: "Ver todo",
  },
  en: {
    title: "Blog",
    subtitle: "Tutorials and notes",
    viewAll: "View all",
  },
};

const t = labels[lang as keyof typeof labels];
---

<div
  aria-labelledby="blog-heading"
  class="flex flex-col h-full bg-gray-50 dark:bg-gray-900 border border-slate-200 dark:border-slate-800 rounded-3xl overflow-hidden group transition-all duration-500"
>
  <div class="px-6 pt-6 pb-0">
    <BentoInternalHeader
      title={t.title}
      subtitle={t.subtitle}
      href={`/${lang}/blog`}
      lang={lang}
      id="blog-heading"
    />
  </div>

  <div class="flex-1 px-4 pt-0 pb-4 space-y-2">
    {
      latestBlogs.map((blog) => (
        <a
          href={blog.url}
          class="flex flex-col p-3 rounded-2xl hover:bg-slate-100 dark:hover:bg-slate-800/50 transition-all group/item"
        >
          <time
            transition:name="blog-date"
            class="text-[9px] font-bold text-slate-400 uppercase tracking-widest mb-1"
          >
            {new Date(blog.pubDate!).toLocaleDateString(lang, {
              year: "numeric",
              month: "short",
              day: "numeric",
            })}
          </time>
          <h4
            transition:name="blog-title"
            class="text-sm font-bold text-slate-800 dark:text-slate-200 truncate group-hover/item:text-blue-600 dark:group-hover/item:text-blue-400 transition-colors"
          >
            {blog.title}
          </h4>
        </a>
      ))
    }
  </div>

  <div
    class="h-1 w-full bg-gradient-to-r from-transparent via-blue-500/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity"
  >
  </div>
</div>
